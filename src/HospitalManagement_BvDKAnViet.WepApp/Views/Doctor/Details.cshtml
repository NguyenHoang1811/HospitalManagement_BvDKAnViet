@model HospitalManagement_BvDKAnViet.WepApp.Models.DoctorDTO.DoctorDto

@{
	ViewData["Title"] = "Chi tiết bác sĩ";
	ViewData["Breadcrumb"] = new List<(string Text, string Url)>
	{
		("Bác sĩ", "/Doctor"),
		("Chi tiết bác sĩ", null!)
	};
}

<div class="page-wrapper container mt-4 mb-5">

	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h3 class="fw-bold text-navy mb-1">@ViewData["Title"]</h3>
			<div class="text-muted small">Hồ sơ thông tin chuyên gia y tế</div>
		</div>

		<a asp-action="Index" class="btn-view-all shadow-sm">
			<i class="fas fa-arrow-left me-1"></i> Quay lại
		</a>
	</div>

	<div class="card-custom p-4 p-md-5">

		<div class="row align-items-center">

			<div class="col-lg-4 mb-4 mb-lg-0 text-center">
				<div class="img-box position-relative shadow">
					<img src="@(Model.DoctorImage ?? "/img/no-image.png")" alt="@Model.Name" onerror="this.onerror=null;this.src='/img/default-doctor.png';" />
				</div>
			</div>

			<div class="col-lg-8 ps-lg-4">

				<div class="profile-header mb-4 pb-4 border-bottom">
					<h2 class="fw-bold text-navy mb-3">@Model.Name</h2>
					<span class="badge bg-teal-light text-teal px-3 py-2 fs-6 rounded-pill">
						<i class="fas fa-stethoscope me-1"></i> @Model.Specialty
					</span>
				</div>

				<div class="row g-4 mb-5">

					<div class="col-md-6">
						<div class="info-item d-flex align-items-center p-3 rounded-4 bg-light border border-light">
							<div class="icon-wrapper text-teal bg-white shadow-sm rounded-circle me-3 d-flex align-items-center justify-content-center">
								<i class="fas fa-phone-alt fs-5"></i>
							</div>
							<div>
								<div class="text-muted small fw-semibold text-uppercase mb-1" style="letter-spacing: 0.5px;">Điện thoại</div>
								<div class="fw-bold text-dark" style="font-size: 15px;">@Model.Phone</div>
							</div>
						</div>
					</div>

					<div class="col-md-6">
						<div class="info-item d-flex align-items-center p-3 rounded-4 bg-light border border-light">
							<div class="icon-wrapper text-teal bg-white shadow-sm rounded-circle me-3 d-flex align-items-center justify-content-center">
								<i class="fas fa-envelope fs-5"></i>
							</div>
							<div>
								<div class="text-muted small fw-semibold text-uppercase mb-1" style="letter-spacing: 0.5px;">Email</div>
								<div class="fw-bold text-dark" style="font-size: 15px; word-break: break-all;">@Model.Email</div>
							</div>
						</div>
					</div>

					<div class="col-md-6">
						<div class="info-item d-flex align-items-center p-3 rounded-4 bg-light border border-light">
							<div class="icon-wrapper text-primary bg-white shadow-sm rounded-circle me-3 d-flex align-items-center justify-content-center">
								<i class="fas fa-hospital fs-5"></i>
							</div>
							<div>
								<div class="text-muted small fw-semibold text-uppercase mb-1" style="letter-spacing: 0.5px;">Khoa công tác</div>
								<div class="badge-soft blue mt-1">
									@ViewBag.DepartmentName
								</div>
							</div>
						</div>
					</div>

				</div>

				<div class="d-flex justify-content-end gap-2 mt-2">
					<a asp-action="Index" class="btn btn-light btn-lg px-4 fs-6">
						Hủy
					</a>
					<a asp-action="Edit" asp-route-id="@Model.DoctorId" class="btn btn-accent btn-lg px-4 fs-6 shadow-sm">
						<i class="fas fa-edit me-1"></i> Cập nhật hồ sơ
					</a>
				</div>

			</div>
		</div>

	</div>
</div>

<style>
	/* ===== COLORS ===== */
	:root {
		--navy: #0f2744;
		--teal: #0d9488;
	}

	.text-navy {
		color: var(--navy) !important;
	}

	.text-teal {
		color: var(--teal) !important;
	}

	.bg-teal-light {
		background-color: #ccfbf1 !important;
	}

	/* ===== PAGE ===== */
	.page-wrapper {
		padding: 10px;
	}

	/* ===== HEADER ===== */
	.btn-view-all {
		background: #ffffff;
		border-radius: 8px;
		padding: 8px 16px;
		text-decoration: none;
		color: #475569;
		font-weight: 600;
		border: 1px solid #e2e8f0;
		transition: all 0.2s;
	}

		.btn-view-all:hover {
			background: #f8fafc;
			color: var(--navy);
		}

	/* ===== CARD ===== */
	.card-custom {
		background: #ffffff;
		border-radius: 20px;
		box-shadow: 0 10px 40px rgba(0,0,0,0.04);
		border: 1px solid rgba(0,0,0,0.03);
	}

	/* ===== IMAGE FRAME ===== */
	.img-box {
		width: 100%;
		max-width: 300px;
		height: 380px; /* Tỉ lệ chân dung hoàn hảo */
		margin: auto;
		border-radius: 16px;
		overflow: hidden;
		background: #f8fafc;
		border: 6px solid #ffffff; /* Viền trắng kiểu polaroid */
	}

		.img-box img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			object-position: top center; /* Giữ phần đầu không bị cắt */
			display: block;
			transition: transform 0.4s ease;
		}

		.img-box:hover img {
			transform: scale(1.05);
		}

	/* ===== INFO GRID ===== */
	.icon-wrapper {
		width: 48px;
		height: 48px;
		flex-shrink: 0;
	}

	.info-item {
		transition: all 0.2s ease;
	}

		.info-item:hover {
			background-color: #ffffff !important;
			box-shadow: 0 4px 15px rgba(0,0,0,0.03);
			border-color: #e2e8f0 !important;
		}

	/* ===== BADGE ===== */
	.badge-soft {
		padding: 6px 14px;
		border-radius: 20px;
		font-size: 13px;
		font-weight: 600;
		display: inline-block;
	}

		.badge-soft.blue {
			background: #eff6ff;
			color: #2563eb;
			border: 1px solid #bfdbfe;
		}

	/* ===== BUTTON ===== */
	.btn-accent {
		background: var(--teal);
		color: white;
		border-radius: 10px;
		font-weight: 600;
		border: none;
		transition: all 0.3s ease;
	}

		.btn-accent:hover {
			background: #0f766e;
			color: white;
			transform: translateY(-2px);
			box-shadow: 0 6px 15px rgba(13, 148, 136, 0.3) !important;
		}

	.btn-light {
		border-radius: 10px;
		font-weight: 600;
		color: #475569;
		border: 1px solid #e2e8f0;
		transition: all 0.3s ease;
	}

		.btn-light:hover {
			background: #f1f5f9;
			color: var(--navy);
		}

	/* ===== RESPONSIVE ===== */
	@@media (max-width: 992px) {
		.img-box {
			max-width: 240px;
			height: 300px;
		}

		.profile-header {
			text-align: center;
		}

		.d-flex.justify-content-end {
			justify-content: center !important;
		}
	}
</style>