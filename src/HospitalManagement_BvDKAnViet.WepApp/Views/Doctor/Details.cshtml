@model HospitalManagement_BvDKAnViet.WepApp.Models.DoctorDTO.DoctorDto

@{
	ViewData["Title"] = "Chi tiết bác sĩ";
	ViewData["Breadcrumb"] = new List<(string Text, string Url)>
	{
		("Bác sĩ", "/Doctor"),
		("Chi tiết bác sĩ", null!)
	};
}

<div class="page-wrapper">

	<!-- HEADER -->
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h4 class="fw-bold mb-1">@ViewData["Title"]</h4>
			<div class="text-muted small">Thông tin chi tiết bác sĩ</div>
		</div>

		<a asp-action="Index" class="btn-view-all">
			<i class="fas fa-arrow-left"></i> Quay lại
		</a>
	</div>

	<!-- CARD -->
	<div class="card-custom p-4">

        <div class="row align-items-center">

			<!-- IMAGE -->
            <div class="col-md-4 mb-3">
                <div class="img-box">
                    <img src="@(Model.DoctorImage ?? "/img/no-image.png")" />
                </div>
            </div>

			<!-- INFO -->
            <div class="col-md-8">

                <div class="info-group">
                    <div class="info-label">Tên bác sĩ</div>
                    <div class="info-value">@Model.Name</div>
                </div>

                <div class="info-group">
                    <div class="info-label">Chuyên khoa</div>
                    <div class="info-value">@Model.Specialty</div>
                </div>

                <div class="info-group">
                    <div class="info-label">Điện thoại</div>
                    <div class="info-value">@Model.Phone</div>
                </div>

                <div class="info-group">
                    <div class="info-label">Email</div>
                    <div class="info-value">@Model.Email</div>
                </div>

                <div class="info-group">
                    <div class="info-label">Khoa</div>
                    <div class="info-value badge-soft blue">
                        @ViewBag.DepartmentName
                    </div>
                </div>

            </div>

		</div>

		<!-- ACTION -->
		<div class="mt-3">
			<a asp-action="Edit" asp-route-id="@Model.DoctorId"
			   class="btn btn-accent">
				<i class="fas fa-edit"></i> Sửa
			</a>

			<a asp-action="Index" class="btn btn-light">Quay lại</a>
		</div>

	</div>
</div>

<style>
    /* ===== PAGE ===== */
    .page-wrapper {
        padding: 16px;
    }

    /* ===== HEADER ===== */
    .btn-view-all {
        background: #f1f5f9;
        border-radius: 8px;
        padding: 6px 12px;
        text-decoration: none;
        color: #334155;
        transition: 0.2s;
    }

        .btn-view-all:hover {
            background: #e2e8f0;
        }

    /* ===== CARD ===== */
    .card-custom {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    /* ===== IMAGE FIX CHUẨN ===== */
    .img-box {
        width: 100%;
        max-width: 280px;
        height: 280px;
        margin: auto;
        border-radius: 16px;
        overflow: hidden;
        background: #f1f5f9;
        box-shadow: 0 12px 30px rgba(0,0,0,0.12);
    }

        .img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* nếu muốn không crop → đổi thành contain */
            display: block;
            transition: 0.3s;
        }

        .img-box:hover img {
            transform: scale(1.05);
        }

    /* ===== INFO ===== */
    .info-group {
        margin-bottom: 14px;
        padding-bottom: 10px;
        border-bottom: 1px dashed #e2e8f0;
    }

        .info-group:last-child {
            border-bottom: none;
        }

    .info-label {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 4px;
    }

    .info-value {
        font-weight: 500;
        color: #0f172a;
        font-size: 15px;
    }

    /* ===== BADGE ===== */
    .badge-soft {
        padding: 6px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

        .badge-soft.blue {
            background: #dbeafe;
            color: #2563eb;
        }

    /* ===== BUTTON ===== */
    .btn-accent {
        background: #2dd4bf;
        color: white;
        border-radius: 8px;
        padding: 6px 14px;
        border: none;
    }

        .btn-accent:hover {
            background: #26c6a8;
        }

    .btn-light {
        border-radius: 8px;
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .img-box {
            max-width: 200px;
            height: 200px;
        }
    }
</style>