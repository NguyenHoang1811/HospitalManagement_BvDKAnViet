@model IEnumerable<HospitalManagement_BvDKAnViet.WepApp.Models.DoctorDTO.DoctorDto>

@{
    ViewData["Title"] = "Danh sách bác sĩ";
    ViewData["Breadcrumb"] = new List<(string, string)>
    {
        ("Bác sĩ", "/Doctor"),
        ("Danh sách bác sĩ", null)
    };
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">@ViewData["Title"]</h2>
            <div class="text-muted small">Quản lý thông tin bác sĩ</div>
        </div>

        <a asp-action="Create" class="btn btn-accent">
            <i class="fas fa-plus"></i> Thêm bác sĩ
        </a>
    </div>

    <!-- ALERT -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    <!-- TABLE -->
    <div class="card-custom">

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-modern align-middle">

                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Mã BS</th>
                            <th>Bác sĩ</th>
                            <th>Chuyên khoa</th>
                            <th>Điện thoại</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            int stt = 1;
                        }

                        @foreach (var d in Model)
                        {
                            <tr>
                                <!-- STT -->
                                <td>
                                    <span class="stt">@stt</span>
                                </td>

                                <!-- ID -->
                                <td>
                                    <span class="id-badge">
                                        BS-@d.DoctorId
                                    </span>
                                </td>

                                <!-- NAME -->
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar">
                                            @d.Name.Substring(0, 1)
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@d.Name</div>
                                            <div class="text-muted small">Doctor</div>
                                        </div>
                                    </div>
                                </td>

                                <td>@d.Specialty</td>

                                <td>@d.Phone</td>

                                <!-- ACTION -->
                                <td class="text-end">

                                    <a asp-action="Details" asp-route-id="@d.DoctorId"
                                       class="btn-action text-info" title="Xem">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@d.DoctorId"
                                       class="btn-action text-warning" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <button type="button"
                                            class="btn-action text-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-id="@d.DoctorId">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>

                            stt++;
                        }
                    </tbody>

                </table>
            </div>
        }
        else
        {
            <div class="text-center p-5 text-muted">
                <i class="fas fa-user-md fa-2x mb-3"></i>
                <div>Không có bác sĩ nào</div>
                <a asp-action="Create" class="btn btn-accent mt-3">Thêm bác sĩ</a>
            </div>
        }
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modern-modal">

            <div class="modal-body text-center p-4">
                <div class="mb-3 text-danger fs-2">
                    <i class="fas fa-trash"></i>
                </div>
                <h5 class="fw-semibold">Xác nhận xóa</h5>
                <p class="text-muted">Bạn có chắc chắn muốn xóa bác sĩ này?</p>

                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-danger px-4">
                        Xóa
                    </button>

                    <button type="button" class="btn btn-light px-4 ms-2" data-bs-dismiss="modal">
                        Hủy
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var deleteModal = document.getElementById('deleteModal');

    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var id = button.getAttribute('data-id');

        var form = document.getElementById('deleteForm');
        form.action = '/Doctor/Delete/' + id;
    });
</script>

<style>
   

    .page-wrapper {
        padding: 10px;
    }

    .card-custom {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.05);
        padding: 10px 0;
    }

    .table-modern thead th {
        font-size: 12px;
        color: #64748b;
        text-transform: uppercase;
        border-bottom: 1px solid #e2e8f0;
    }

    .table-modern tbody tr:hover {
        background: #f8fafc;
    }

    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #60a5fa;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    .btn-accent {
        background: #2dd4bf;
        color: white;
        border-radius: 8px;
    }

        .btn-accent:hover {
            background: #26c6a8;
        }

    .btn-action {
        margin-left: 6px;
        font-size: 14px;
    }

    .modern-modal {
        border-radius: 14px;
        border: none;
    }

    .stt {
        font-weight: 600;
        color: #64748b;
    }

    .id-badge {
        background: #f1f5f9;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
    }
</style>