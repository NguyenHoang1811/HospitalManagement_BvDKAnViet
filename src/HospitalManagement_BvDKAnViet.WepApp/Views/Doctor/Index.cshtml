@model IEnumerable<HospitalManagement_BvDKAnViet.WepApp.Models.DoctorDTO.DoctorDto>

@{
    ViewData["Title"] = "Danh sách bác sĩ";

    // Lấy thông tin phân trang từ ViewBag
    string searchTerm = ViewBag.SearchTerm as string;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalPages = ViewBag.TotalPages ?? 1;

    ViewData["Breadcrumb"] = new List<(string, string)>
    {
        ("Bác sĩ", "/Doctor"),
        ("Danh sách bác sĩ", null)
    };
}

<div class="page-wrapper container mt-4 mb-5">

    <!-- HEADER -->
    <div class="page-action-bar mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-navy mb-1" style="font-size: 24px;">@ViewData["Title"]</h2>
            <div class="text-muted small">Quản lý thông tin bác sĩ</div>
        </div>

        <a asp-action="Create" class="btn btn-accent px-4 py-2 shadow-sm">
            <i class="fas fa-plus me-1"></i> Thêm bác sĩ
        </a>
    </div>

    <!-- TOOLBAR (Bộ lọc và Tìm kiếm) -->
    <div class="card-custom mb-4 px-4 py-3 bg-light border-0">
        <form asp-action="Index" method="get"
              class="d-flex justify-content-between align-items-center m-0 flex-wrap gap-3">

            <!-- LEFT -->
            <div class="d-flex align-items-center gap-3">

                <!-- Page size -->
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small text-uppercase">Hiển thị:</span>
                    <select name="pageSize" class="form-select form-control-custom"
                            style="width: 80px;" onchange="this.form.submit()">
                        <option value="5" selected="@(pageSize == 5)">5</option>
                        <option value="10" selected="@(pageSize == 10)">10</option>
                        <option value="20" selected="@(pageSize == 20)">20</option>
                        <option value="50" selected="@(pageSize == 50)">50</option>
                    </select>
                </div>

                <!-- FILTER KHOA -->
                <select name="departmentId"
                        class="form-select form-control-custom"
                        style="width: 200px;"
                        onchange="this.form.submit()">
                    <option value="">-- Tất cả khoa --</option>
                    @foreach (var d in (SelectList)ViewBag.Departments)
                    {
                        <option value="@d.Value" selected="@(d.Value == (ViewBag.DepartmentId?.ToString()))">
                            @d.Text
                        </option>
                    }
                </select>

            </div>

            <!-- SEARCH -->
            <div class="input-group input-group-custom shadow-sm" style="width: 320px;">
                <input type="text" name="searchTerm"
                       class="form-control form-control-custom border-end-0"
                       placeholder="Tìm tên bác sĩ..."
                       value="@searchTerm">

                <button class="btn btn-accent px-3" type="submit">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>
    </div>

    <!-- ALERT -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px;">
            <i class="fas fa-check-circle me-2 fs-5 align-middle"></i>
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- TABLE CARD -->
    <div class="card-custom">

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-modern align-middle mb-0">

                    <thead>
                        <tr>
                            <th class="text-center" width="5%">STT</th>
                            <th>Mã BS</th>
                            <th>Bác sĩ</th>
                            <th>Chuyên khoa</th>
                            <th>Điện thoại</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            // Tính toán lại STT theo trang
                            int stt = ((currentPage - 1) * pageSize) + 1;
                        }

                        @foreach (var d in Model)
                        {
                            <tr>
                                <td class="text-center"><span class="stt">@stt</span></td>

                                <!-- ID -->
                                <td>
                                    <span class="badge-soft gray shadow-sm">BS-@d.DoctorId</span>
                                </td>

                                <!-- NAME -->
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar shadow-sm">
                                            @d.Name.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold text-navy" style="font-size: 15px;">@d.Name</div>
                                            <div class="text-muted small">Doctor</div>
                                        </div>
                                    </div>
                                </td>

                                <!-- SPECIALTY & PHONE -->
                                <td><span class="badge-soft blue shadow-sm">@d.Specialty</span></td>
                                <td class="fw-medium text-navy">@d.Phone</td>

                                <!-- ACTION -->
                                <td class="text-end pe-4">
                                    <div class="action-buttons d-inline-flex gap-2 justify-content-end">

                                        <!-- Create Account -->
                                        <a asp-controller="Account" asp-action="Create" asp-route-doctorId="@d.DoctorId" class="btn-action btn-create-acc" title="Tạo tài khoản">
                                            <i class="fas fa-user-plus"></i>
                                        </a>

                                        <!-- Details -->
                                        <a asp-action="Details" asp-route-id="@d.DoctorId" class="btn-action btn-view" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>

                                        <!-- Edit -->
                                        <a asp-action="Edit" asp-route-id="@d.DoctorId" class="btn-action btn-edit" title="Chỉnh sửa">
                                            <i class="fas fa-pen"></i>
                                        </a>

                                        <!-- Delete -->
                                        <button class="btn-action btn-delete border-0"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteModal"
                                                data-id="@d.DoctorId" title="Xóa bác sĩ">
                                            <i class="fas fa-trash"></i>
                                        </button>

                                    </div>
                                </td>
                            </tr>
                            stt++;
                        }
                    </tbody>

                </table>
            </div>

            <!-- PAGINATION FOOTER -->
            <div class="d-flex justify-content-between align-items-center p-4 border-top bg-light" style="border-radius: 0 0 16px 16px;">
                <div class="small text-muted fw-medium">
                    Trang <b class="text-navy">@currentPage</b> / <b>@totalPages</b>
                </div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 shadow-sm">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-route-page="@(currentPage - 1)"
                               asp-route-pageSize="@pageSize"
                               asp-route-searchTerm="@searchTerm"
                               asp-route-departmentId="@ViewBag.DepartmentId">
                                <i class="fas fa-chevron-left me-1"></i> Trước
                            </a>
                        </li>

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link px-3" asp-route-page="@i"
                                   asp-route-pageSize="@pageSize" asp-route-searchTerm="@searchTerm">@i</a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link px-3" asp-route-page="@(currentPage + 1)"
                               asp-route-pageSize="@pageSize" asp-route-searchTerm="@searchTerm">
                                Sau <i class="fas fa-chevron-right ms-1"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
        else
        {
            <div class="text-center py-5 my-4 text-muted">
                <i class="fas fa-user-md fa-4x mb-3 opacity-50"></i>
                <h5 class="fw-bold text-navy">Không tìm thấy bác sĩ</h5>
                <p class="small mb-4">Hệ thống chưa có dữ liệu hoặc không khớp với từ khóa tìm kiếm của bạn.</p>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                    <i class="fas fa-sync-alt me-1"></i> Làm mới danh sách
                </a>
            </div>
        }
    </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg" style="border-radius: 20px; border: none;">

            <div class="modal-body text-center p-5">
                <div class="mb-4">
                    <div class="mx-auto bg-danger-light text-danger d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; border-radius: 50%;">
                        <i class="fas fa-trash-alt fs-2"></i>
                    </div>
                </div>

                <h4 class="fw-bold text-navy mb-2">Xác nhận xóa</h4>
                <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa bác sĩ này không? Hành động này không thể khôi phục.</p>

                <form id="deleteForm" method="post" class="d-flex justify-content-center gap-3">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn btn-light btn-lg px-4 fw-medium rounded-pill" data-bs-dismiss="modal">
                        Hủy bỏ
                    </button>
                    <button type="submit" class="btn btn-danger btn-lg px-4 fw-medium rounded-pill shadow-sm">
                        Đồng ý xóa
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        var deleteModal = document.getElementById('deleteModal');

        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');

            var form = document.getElementById('deleteForm');
            form.action = '/Doctor/Delete/' + id;
        });
    </script>
}

<style>
    /* VARIABLES */
    :root {
        --navy: #0f2744;
        --teal: #2dd4bf;
    }

    .text-navy { color: var(--navy) !important; }
    .text-teal { color: var(--teal) !important; }

    /* FORM CONTROLS & TOOLBAR */
    .form-control-custom {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #334155;
        transition: all 0.3s ease;
    }

    .form-control-custom:focus {
        background-color: #fff;
        border-color: var(--teal);
        box-shadow: 0 0 0 0.25rem rgba(13, 148, 136, 0.15);
    }

    .input-group-custom .btn-light {
        background-color: #f8fafc;
        border-color: #e2e8f0;
    }

    .input-group-custom .btn-light:hover {
        background-color: #f1f5f9;
        color: #ef4444 !important;
    }

    /* CARD */
    .card-custom {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.04);
        padding: 0;
    }

    /* TABLE */
    .table-modern thead th {
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        border-bottom: 2px solid #f1f5f9;
        background: #f8fafc;
        padding: 16px 12px;
    }

    .table-modern tbody td {
        padding: 16px 12px;
        border-bottom: 1px dashed #f1f5f9;
        color: #334155;
    }

    .table-modern tbody tr:hover {
        background: #fdfdfe;
    }

    .table-modern tbody tr:last-child td {
        border-bottom: none;
    }

    .stt {
        font-weight: 600;
        color: #94a3b8;
    }

    /* AVATAR */
    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #0ea5e9;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    /* BADGES */
    .badge-soft {
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
        border: 1px solid transparent;
    }

    .badge-soft.blue { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
    .badge-soft.gray { background: #f8fafc; color: #475569; border-color: #e2e8f0; }

    /* ACTION BUTTONS DỒNG BỘ */
    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .btn-action {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: 0.2s;
        border: none;
    }

    .btn-create-acc {
        background: #f0fdf4;
        color: #16a34a;
    }
    .btn-create-acc:hover { background: #16a34a; color: white; transform: translateY(-2px); }

    .btn-view {
        background: #f3e8ff;
        color: #9333ea;
    }
    .btn-view:hover { background: #9333ea; color: white; transform: translateY(-2px); }

    .btn-edit {
        background: #eff6ff;
        color: #3b82f6;
    }
    .btn-edit:hover { background: #3b82f6; color: white; transform: translateY(-2px); }

    .btn-delete {
        background: #fef2f2;
        color: #ef4444;
    }
    .btn-delete:hover { background: #ef4444; color: white; transform: translateY(-2px); }

    .btn-accent {
        background: var(--teal);
        color: white;
        border-radius: 8px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-accent:hover {
            background: #26c6a8;
            color: white;
            transform: translateY(-2px);
        }

    /* MODAL */
    .bg-danger-light { background-color: #fee2e2; }

    /* CUSTOM PAGINATION */
    .pagination .page-item .page-link {
        color: #475569;
        border: 1px solid #e2e8f0;
        margin: 0 2px;
        border-radius: 6px;
    }
    .pagination .page-item.active .page-link {
        background-color: var(--teal);
        border-color: var(--teal);
        color: white;
    }
</style>