@model IEnumerable<HospitalManagement_BvDKAnViet.WepApp.Models.ViewModels.KidneyPredictionResultViewModel>

@{
    ViewData["Title"] = "Danh sách dự đoán của tôi";

    // Lấy thông tin phân trang từ ViewBag
    string searchTerm = ViewBag.SearchTerm as string;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int totalPages = ViewBag.TotalPages ?? 1;

    ViewData["Breadcrumb"] = new List<(string, string)>
    {
        ("Dự đoán AI", "/KidneyPrediction"),
        ("Danh sách dự đoán", null)
    };
}

<div class="page-wrapper container mt-4 mb-5">

    <!-- HEADER -->
    <div class="page-action-bar mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-navy mb-1" style="font-size: 24px;">Danh sách dự đoán của bác sĩ</h2>
            <div class="text-muted small">Lịch sử các ca chẩn đoán bệnh thận mạn (CKD) qua AI</div>
        </div>

        <a href="@Url.Action("Index")" class="btn btn-light border shadow-sm px-4 py-2">
            <i class="fas fa-arrow-left me-1"></i> Trở về trang Dự đoán
        </a>
    </div>

    <!-- TOOLBAR (Bộ lọc và Tìm kiếm) -->
    <div class="card-custom mb-4 px-4 py-3 bg-light border-0">
        <form asp-action="MyPredictions" method="get" class="d-flex justify-content-between align-items-center m-0 flex-wrap gap-3">

            <!-- Chọn số dòng -->
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small fw-medium text-uppercase" style="letter-spacing: 0.5px;">Hiển thị:</span>
                <select name="pageSize" class="form-select form-control-custom cursor-pointer" style="width: 80px;" onchange="this.form.submit()">
                    <option value="5" selected="@(pageSize == 5)">5</option>
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="20" selected="@(pageSize == 20)">20</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                </select>
                <span class="text-muted small">dòng / trang</span>
            </div>

            <!-- Ô tìm kiếm -->
            <div class="input-group input-group-custom shadow-sm" style="width: 320px;">
                <input type="text" name="searchTerm" class="form-control form-control-custom border-end-0" placeholder="Tìm tên hoặc ID bệnh nhân..." value="@searchTerm">

                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <a asp-action="MyPredictions" class="btn btn-light border border-start-0 border-end-0 d-flex align-items-center text-muted" title="Xóa tìm kiếm">
                        <i class="fas fa-times"></i>
                    </a>
                }

                <button class="btn btn-accent px-3" type="submit" style="border-radius: 0 8px 8px 0;">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>
    </div>

    <!-- ALERT -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px;">
            <i class="fas fa-exclamation-triangle me-2 fs-5 align-middle"></i>
            <strong>Lỗi!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- TABLE CARD -->
    <div class="card-custom">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-modern align-middle mb-0">

                    <thead>
                        <tr>
                            <th class="text-center" width="5%">STT</th>
                            <th>Bệnh nhân</th>
                            <th>Kết luận</th>
                            <th>Xác suất</th>
                            <th>Mức độ rủi ro</th>
                            <th class="text-end pe-4">Thời gian</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            // STT theo trang
                            int stt = ((currentPage - 1) * pageSize) + 1;
                        }

                        @foreach (var item in Model)
                        {
                            var isCkd = item.PredictionResult?.ToLower() == "ckd";
                            var badgeClass = isCkd ? "badge-soft red" : "badge-soft green";
                            var textClass = isCkd ? "text-danger" : "text-success";

                            var riskClass = item.RiskLevel switch
                            {
                                "HIGH" => "badge-soft red",
                                "MEDIUM" => "badge-soft yellow",
                                "LOW" => "badge-soft green",
                                _ => "badge-soft gray"
                            };

                            <tr>
                                <td class="text-center"><span class="stt">@stt</span></td>

                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar shadow-sm">
                                            @(string.IsNullOrEmpty(item.PatientName) ? "?" : item.PatientName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <div class="fw-bold text-navy" style="font-size: 15px;">@item.PatientName</div>
                                            <div class="text-muted small">Mã: BN-@item.PatientId</div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="@badgeClass shadow-sm px-3">
                                        @(isCkd ? "CKD (Có bệnh)" : "Bình thường")
                                    </span>
                                </td>

                                <td>
                                    <span class="fw-bold @textClass">
                                        @{
                                            // Lấy xác suất tương ứng với kết luận chẩn đoán
                                            var prob = isCkd ? item.ProbabilityCkd : item.ProbabilityNotCkd;
                                        }
                                        @(prob.HasValue ? (prob.Value * 100).ToString("0.##") + "%" : "N/A")
                                    </span>
                                </td>

                                <td>
                                    <span class="@riskClass shadow-sm px-3">
                                        @item.RiskLevel
                                    </span>
                                </td>

                                <td class="text-end pe-4">
                                    <span class="small text-muted fw-medium">
                                        <i class="far fa-clock me-1 opacity-50"></i>
                                        <!-- Đã đổi PredictedAt thành CreatedAt -->
                                        @(item.CreatedAt.HasValue? item.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")
                                    </span>
                                </td>
                            </tr>
                            stt++;
                        }
                    </tbody>

                </table>
            </div>

            <!-- PAGINATION FOOTER -->
            <div class="d-flex justify-content-between align-items-center p-4 border-top bg-light" style="border-radius: 0 0 16px 16px;">
                <div class="small text-muted fw-medium">
                    Trang <b class="text-navy">@currentPage</b> / <b>@totalPages</b>
                </div>
                <nav>
                    <ul class="pagination pagination-sm mb-0 shadow-sm">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link px-3" asp-route-page="@(currentPage - 1)"
                               asp-route-pageSize="@pageSize" asp-route-searchTerm="@searchTerm">
                                <i class="fas fa-chevron-left me-1"></i> Trước
                            </a>
                        </li>

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link px-3" asp-route-page="@i"
                                   asp-route-pageSize="@pageSize" asp-route-searchTerm="@searchTerm">@i</a>
                            </li>
                        }

                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link px-3" asp-route-page="@(currentPage + 1)"
                               asp-route-pageSize="@pageSize" asp-route-searchTerm="@searchTerm">
                                Sau <i class="fas fa-chevron-right ms-1"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
        else
        {
            <div class="text-center py-5 my-4 text-muted">
                <i class="fas fa-robot fa-4x mb-3 opacity-50"></i>
                <h5 class="fw-bold text-navy">Chưa có dữ liệu dự đoán</h5>
                <p class="small mb-4">Hệ thống chưa ghi nhận ca phân tích nào của bạn hoặc không có dữ liệu khớp với bộ lọc.</p>
                <a asp-action="Index" class="btn btn-outline-primary px-4 py-2 rounded-pill shadow-sm">
                    <i class="fas fa-plus me-1"></i> Tạo dự đoán mới ngay
                </a>
            </div>
        }
    </div>
</div>

<style>
    /* VARIABLES (Màu Xanh Ngọc --teal: #2dd4bf) */
    :root {
        --navy: #0f2744;
        --teal: #2dd4bf;
        --teal-hover: #26c6a8;
    }

    .text-navy {
        color: var(--navy) !important;
    }

    .text-teal {
        color: var(--teal) !important;
    }

    /* FORM CONTROLS & TOOLBAR */
    .form-control-custom {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #334155;
        transition: all 0.3s ease;
    }

        .form-control-custom:focus {
            background-color: #fff;
            border-color: var(--teal);
            box-shadow: 0 0 0 0.25rem rgba(45, 212, 191, 0.15);
        }

    .input-group-custom .btn-light {
        background-color: #f8fafc;
        border-color: #e2e8f0;
    }

        .input-group-custom .btn-light:hover {
            background-color: #f1f5f9;
            color: #ef4444 !important;
        }

    /* CARD */
    .card-custom {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.04);
        padding: 0;
    }

    /* TABLE */
    .table-modern thead th {
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        border-bottom: 2px solid #f1f5f9;
        background: #f8fafc;
        padding: 16px 12px;
    }

    .table-modern tbody td {
        padding: 16px 12px;
        border-bottom: 1px dashed #f1f5f9;
        color: #334155;
        transition: background-color 0.2s;
    }

    .table-modern tbody tr:hover td {
        background: #fdfdfe;
    }

    .table-modern tbody tr:last-child td {
        border-bottom: none;
    }

    .stt {
        font-weight: 600;
        color: #94a3b8;
    }

    /* AVATAR */
    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #60a5fa;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    /* BADGES */
    .badge-soft {
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
        border: 1px solid transparent;
    }

        .badge-soft.green {
            background: #f0fdf4;
            color: #15803d;
            border-color: #bbf7d0;
        }

        .badge-soft.yellow {
            background: #fef9c3;
            color: #ca8a04;
            border-color: #fde047;
        }

        .badge-soft.red {
            background: #fef2f2;
            color: #b91c1c;
            border-color: #fecaca;
        }

        .badge-soft.gray {
            background: #f8fafc;
            color: #475569;
            border-color: #e2e8f0;
        }

    /* BUTTON ACCENT (#2dd4bf) */
    .btn-accent {
        background: var(--teal);
        color: white;
        border-radius: 8px;
        font-weight: 600;
        transition: 0.3s;
        border: none;
    }

        .btn-accent:hover {
            background: var(--teal-hover);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(45, 212, 191, 0.2);
        }

    /* CUSTOM PAGINATION */
    .pagination .page-item .page-link {
        color: #475569;
        border: 1px solid #e2e8f0;
        margin: 0 2px;
        border-radius: 6px;
    }

    .pagination .page-item.active .page-link {
        background-color: var(--teal);
        border-color: var(--teal);
        color: white;
    }
</style>