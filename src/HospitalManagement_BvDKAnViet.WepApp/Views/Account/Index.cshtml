@model IEnumerable<HospitalManagement_BvDKAnViet.WepApp.Models.AccountDTO.UserDto>

@{
    ViewData["Title"] = "Danh sách tài khoản";

    ViewData["Breadcrumb"] = new List<(string, string)>
    {
        ("Tài khoản", "/Account"),
        ("Danh sách tài khoản", null)
    };
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">@ViewData["Title"]</h2>
            <div class="text-muted small">Quản lý người dùng hệ thống</div>
        </div>

        <a asp-action="Create" class="btn btn-accent">
            <i class="fas fa-user-plus"></i> Thêm tài khoản
        </a>
    </div>

    <!-- ALERT -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    <!-- CARD -->
    <div class="card-custom">

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-modern align-middle">

                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Username</th>
                            <th>Vai trò</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            int stt = 1;
                        }

                        @foreach (var u in Model)
                        {
                            <tr>
                                <td><span class="stt">@stt</span></td>

                                <!-- USER -->
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar">
                                            @u.Username.Substring(0, 1)
                                        </div>
                                        <div class="fw-semibold">
                                            @u.Username
                                        </div>
                                    </div>
                                </td>

                                <!-- ROLE -->
                                <td>
                                    @{
                                        var roleClass = u.RoleName switch
                                        {
                                            "Admin" => "badge bg-danger",
                                            "Doctor" => "badge bg-primary",
                                            "Staff" => "badge bg-success",
                                            _ => "badge bg-secondary"
                                        };
                                    }
                                    <span class="@roleClass">@u.RoleName</span>
                                </td>

                                <!-- ACTION -->
                                <td class="text-end">

                                    <form asp-action="ResetPassword" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.UserId" />

                                        <button type="submit"
                                                class="btn-action text-warning"
                                                onclick="return confirm('Reset mật khẩu về 123456?')"
                                                title="Reset mật khẩu">
                                            <i class="fas fa-key"></i>
                                        </button>
                                    </form>

                                    <a asp-action="Edit" asp-route-id="@u.UserId"
                                       class="btn-action text-warning" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <button class="btn-action text-danger"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal"
                                            data-id="@u.UserId">
                                        <i class="fas fa-trash"></i>
                                    </button>

                                </td>
                            </tr>
                            stt++;
                        }
                    </tbody>

                </table>
            </div>
        }
        else
        {
            <div class="text-center p-5 text-muted">
                <i class="fas fa-users fa-2x mb-3"></i>
                <div>Không có tài khoản</div>
            </div>
        }
    </div>
</div>

<!-- DELETE MODAL (y hệt MedicalRecord) -->
<div class="modal fade" id="deleteModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modern-modal">

            <div class="modal-body text-center p-4">
                <div class="text-danger fs-2 mb-3">
                    <i class="fas fa-trash"></i>
                </div>

                <h5>Xác nhận xóa</h5>
                <p>Bạn có chắc muốn xóa tài khoản này?</p>

                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()

                    <button class="btn btn-danger px-4">Xóa</button>
                    <button type="button" class="btn btn-light ms-2" data-bs-dismiss="modal">Hủy</button>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var modal = document.getElementById('deleteModal');

    modal.addEventListener('show.bs.modal', function (e) {
        var id = e.relatedTarget.getAttribute("data-id");
        document.getElementById("deleteForm").action = "/Account/Delete/" + id;
    });
</script>

<style>
    /* LAYOUT */
    .page-wrapper {
        padding: 10px;
    }

    /* CARD */
    .card-custom {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.05);
        padding: 10px 0;
    }

    /* TABLE */
    .table-modern {
        margin: 0;
    }

        .table-modern thead th {
            font-size: 12px;
            color: #64748b;
            text-transform: uppercase;
            border-bottom: 1px solid #e2e8f0;
        }

        .table-modern tbody tr:hover {
            background: #f8fafc;
        }

    /* AVATAR */
    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #60a5fa;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
    }

    /* BUTTON ACTION */
    .btn-action {
        margin-left: 6px;
        font-size: 14px;
        cursor: pointer;
    }

    /* BUTTON ACCENT */
    .btn-accent {
        background: #2dd4bf;
        color: white;
        border-radius: 8px;
        border: none;
        padding: 8px 14px;
        font-weight: 500;
        transition: 0.2s;
    }

        .btn-accent:hover {
            background: #26c6a8;
            color: white;
        }

    /* MODAL */
    .modern-modal {
        border-radius: 14px;
        border: none;
    }

    /* STT */
    .stt {
        font-weight: 600;
        color: #64748b;
    }

    .btn-action.text-warning {
        color: #f59e0b;
    }

        .btn-action.text-warning:hover {
            color: #d97706;
        }
</style>