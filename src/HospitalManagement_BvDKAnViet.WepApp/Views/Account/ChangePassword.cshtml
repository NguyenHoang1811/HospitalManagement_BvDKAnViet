@model HospitalManagement_BvDKAnViet.WepApp.Models.AccountDTO.ChangePasswordDto

@{
    ViewData["Title"] = "Đổi mật khẩu";

    ViewData["Breadcrumb"] = new List<(string, string)>
    {
        ("Tài khoản", "/Account"),
        ("Đổi mật khẩu", null)
    };
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">@ViewData["Title"]</h4>
            <div class="text-muted small">Cập nhật mật khẩu người dùng</div>
        </div>

        <a asp-action="Index" class="btn-view-all">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <!-- CARD -->
    <div class="card-custom p-4">

        <!-- USER INFO -->
        <div class="alert alert-info mb-3">
            <i class="fas fa-user"></i>
            Tài khoản: <b>@ViewBag.Username</b>
        </div>

        <!--validate--></>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <form method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="UserId" />

            <div class="row">

                <!-- CURRENT PASSWORD -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Mật khẩu hiện tại</label>
                    <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="Nhập mật khẩu hiện tại..." />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <!-- NEW PASSWORD -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Mật khẩu mới</label>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="Nhập mật khẩu mới..." />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <!-- CONFIRM -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Xác nhận mật khẩu mới</label>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu..." />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                </div>

            </div>

            <!-- ACTION -->
            <div class="mt-3">
                <button type="submit" class="btn btn-accent">
                    <i class="fas fa-key"></i> Đổi mật khẩu
                </button>

                <a asp-action="Index" class="btn btn-light">Hủy</a>
            </div>

        </form>
    </div>
</div>

<style>
    /* ===== LAYOUT ===== */
    .page-wrapper {
        padding: 12px;
    }

    /* ===== CARD ===== */
    .card-custom {
        background: #ffffff;
        border-radius: 14px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
        transition: 0.2s;
    }

        .card-custom:hover {
            box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
        }

    /* ===== HEADER TEXT ===== */
    h4 {
        color: #0f172a;
    }

    .text-muted {
        color: #64748b !important;
    }

    /* ===== INPUT ===== */
    .form-control {
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        padding: 8px 12px;
        transition: 0.2s;
    }

        .form-control:focus {
            border-color: #2dd4bf;
            box-shadow: 0 0 0 2px rgba(45, 212, 191, 0.15);
        }

    /* ===== LABEL ===== */
    .form-label {
        font-weight: 500;
        margin-bottom: 6px;
        color: #334155;
    }

    /* ===== BUTTON PRIMARY ===== */
    .btn-accent {
        background: #2dd4bf;
        color: #fff;
        border-radius: 8px;
        border: none;
        padding: 8px 16px;
        font-weight: 500;
        transition: 0.2s;
    }

        .btn-accent:hover {
            background: #26c6a8;
            color: #fff;
        }

    /* ===== BUTTON BACK ===== */
    .btn-view-all {
        background: #f1f5f9;
        border-radius: 8px;
        padding: 6px 12px;
        text-decoration: none;
        color: #334155;
        transition: 0.2s;
    }

        .btn-view-all:hover {
            background: #e2e8f0;
        }

    /* ===== ALERT ===== */
    .alert {
        border-radius: 10px;
        font-size: 14px;
    }

    .alert-info {
        background: #e0f2fe;
        color: #0369a1;
        border: none;
    }

    /* ===== VALIDATION ===== */
    .text-danger {
        font-size: 13px;
    }

    /* ===== SPACING ===== */
    .mb-3 {
        margin-bottom: 14px !important;
    }

    /* ===== ICON ===== */
    .fas {
        margin-right: 4px;
    }
</style>