@model HospitalManagement_BvDKAnViet.WepApp.Models.AccountDTO.ChangePasswordDto

@{
	ViewData["Title"] = "Đổi mật khẩu";

	ViewData["Breadcrumb"] = new List<(string, string)>
	{
		("Trang chủ", "/Home"),
		("Đổi mật khẩu", null)
	};
}

<div class="card-custom p-4">

	<!-- HEADER -->
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h4 class="fw-bold mb-1">Đổi mật khẩu</h4>
			<div class="text-muted small">
				Cập nhật mật khẩu để bảo mật tài khoản
			</div>
		</div>

		<a asp-controller="Home" asp-action="Index" class="btn-view-all">
			<i class="fas fa-arrow-left"></i> Quay lại
		</a>
	</div>

	<!-- VALIDATION SUMMARY -->
	<div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

	<form method="post">
		@Html.AntiForgeryToken()

		<div class="row">

			<!-- CURRENT PASSWORD -->
			<div class="col-md-6 mb-3">
				<label asp-for="CurrentPassword" class="form-label"></label>
				<input asp-for="CurrentPassword" type="password" class="form-control" />
				<span asp-validation-for="CurrentPassword" class="text-danger"></span>
			</div>

			<!-- NEW PASSWORD -->
			<div class="col-md-6 mb-3">
				<label asp-for="NewPassword" class="form-label"></label>
				<input asp-for="NewPassword" type="password" class="form-control" />
				<span asp-validation-for="NewPassword" class="text-danger"></span>
			</div>

			<!-- CONFIRM -->
			<div class="col-md-6 mb-3">
				<label asp-for="ConfirmNewPassword" class="form-label"></label>
				<input asp-for="ConfirmNewPassword" type="password" class="form-control" />
				<span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
			</div>

		</div>

		<!-- ACTION -->
		<div class="mt-3 d-flex gap-2">
			<button type="submit" class="btn-primary-hms">
				<i class="fas fa-key"></i> Đổi mật khẩu
			</button>

			<a asp-controller="Home" asp-action="Index" class="btn-cancel">
				Hủy
			</a>
		</div>

	</form>
</div>

<style>
	.card-custom {
		background: #fff;
		border-radius: 14px;
		box-shadow: 0 8px 24px rgba(0,0,0,0.05);
	}

	.btn-cancel {
		background: #f1f5f9;
		border-radius: 10px;
		padding: 8px 16px;
		text-decoration: none;
		color: #334155;
		display: inline-flex;
		align-items: center;
	}

		.btn-cancel:hover {
			background: #e2e8f0;
			color: #334155;
		}
</style>