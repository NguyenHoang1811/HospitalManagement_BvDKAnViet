@model HospitalManagement_BvDKAnViet.WepApp.Models.MedicineDTO.UpdateMedicineDto

@{
	ViewData["Title"] = "Sửa thuốc";
	ViewData["Breadcrumb"] = new List<(string, string)>
	{
		("Thuốc", "/Medicine"),
		("Sửa thuốc", null)
	};
}

<div class="card-custom p-4">

	<div class="d-flex justify-content-between mb-4">
		<h4 class="fw-bold">Cập nhật thuốc</h4>

		<a asp-action="Index" class="btn-view-all">
			<i class="fas fa-arrow-left"></i> Quay lại
		</a>
	</div>

	<div asp-validation-summary="ModelOnly" class="text-danger"></div>

	<form method="post" asp-route-id="@ViewBag.MedicineId">
		@Html.AntiForgeryToken()

		<div class="row">

			<div class="col-md-6 mb-3">
				<label class="form-label">Tên thuốc</label>
				<input asp-for="Name" class="form-control" />
				<span asp-validation-for="Name" class="text-danger"></span>
			</div>

			<div class="col-md-6 mb-3">
				<label class="form-label">Giá</label>
				<input asp-for="Price" class="form-control" />
				<span asp-validation-for="Price" class="text-danger"></span>
			</div>

		</div>

		<button class="btn btn-accent">
			<i class="fas fa-save"></i> Lưu
		</button>

		<a asp-action="Index" class="btn btn-light">Hủy</a>
	</form>
</div>

<style>
	.card-custom {
		background: #fff;
		border-radius: 14px;
		box-shadow: 0 8px 24px rgba(0,0,0,0.05);
	}

	.btn-accent {
		background: #2dd4bf;
		color: #fff;
		border-radius: 8px;
		padding: 8px 14px;
	}

	.btn-view-all {
		background: #f1f5f9;
		padding: 6px 12px;
		border-radius: 8px;
	}

	.table-modern th {
		background: #f8fafc;
	}

	.btn-action {
		margin-left: 8px;
		font-size: 16px;
	}
</style>