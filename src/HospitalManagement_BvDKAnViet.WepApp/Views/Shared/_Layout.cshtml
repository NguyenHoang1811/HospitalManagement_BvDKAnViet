		</nav>
		<!-- /.hms-sidebar -->
		<!-- ═══ MAIN ═══ -->
		<div class="hms-main">

			<!-- TOP BAR -->
			<header class="hms-topbar">

				<!-- Search pill — centered -->
				<!--<div class="tb-search">
					<i class="fas fa-magnifying-glass"></i>
					<input id="globalSearch" type="text" placeholder="Tìm bệnh nhân, bác sĩ, thuốc..." autocomplete="off" />
				</div>-->



				<!-- Right side -->
				<div class="tb-right">

					<!-- Quick Actions dropdown -->
					<div class="dropdown">
						<button class="tb-btn" data-bs-toggle="dropdown" aria-expanded="false">
							<i class="fas fa-plus"></i>
							Thao Tác Nhanh
							<i class="fas fa-chevron-down" style="font-size:9px;"></i>
						</button>
						<ul class="dropdown-menu dropdown-menu-end" style="font-size:13px;min-width:190px;border-radius:10px;border:1px solid var(--border);box-shadow:0 8px 24px rgba(0,0,0,0.1);">
							<li><a class="dropdown-item" asp-controller="Patient" asp-action="Create"><i class="fas fa-user-plus me-2 text-muted" style="width:16px;"></i>Thêm bệnh nhân</a></li>
							<li><a class="dropdown-item" asp-controller="MedicalRecord" asp-action="Create"><i class="fas fa-file-circle-plus me-2 text-muted" style="width:16px;"></i>Tạo bệnh án</a></li>
							<li><a class="dropdown-item" href="#"><i class="fas fa-calendar-plus me-2 text-muted" style="width:16px;"></i>Đặt lịch khám</a></li>
							<li><hr class="dropdown-divider"></li>
							<li><a class="dropdown-item" href="#"><i class="fas fa-chart-bar me-2 text-muted" style="width:16px;"></i>Xuất báo cáo</a></li>
						</ul>
					</div>

					<!-- Notification bell -->
					<div class="tb-notif">
						<i class="fas fa-bell"></i>
						<span class="notif-dot"></span>
					</div>

					<div class="tb-divider"></div>

					<!-- Date-time -->
					<div class="tb-datetime">
						<div class="tb-time" id="tb-clock">@DateTime.Now.ToString("HH:mm")</div>
						<div class="tb-date">@DateTime.Now.ToString("dd/MM/yyyy")</div>
					</div>

				</div>
			</header>
			<!-- /.hms-topbar -->
			<!-- CONTENT AREA -->
			<div class="hms-content">

				<!-- Page header -->
				<div class="page-header">

					<!-- BREADCRUMB -->
					@if (ViewData["Breadcrumb"] != null)
					{
						<nav aria-label="breadcrumb">
							<ol class="breadcrumb mb-1">
								@foreach (var item in (List<(string Text, string Url)>)ViewData["Breadcrumb"])
								{
									if (!string.IsNullOrEmpty(item.Url))
									{
										<li class="breadcrumb-item">
											<a href="@item.Url">@item.Text</a>
										</li>
									}
									else
									{
										<li class="breadcrumb-item active fw-semibold" aria-current="page">
											@item.Text
										</li>
									}
								}
							</ol>
						</nav>
					}
				</div>

				<!-- Child page renders here -->
				<main role="main">
					@RenderBody()
				</main>

			</div>
			<!-- /.hms-content -->

			<footer class="hms-footer">
				&copy; 2026 — Hệ Thống Quản Lý Bệnh Viện Đa Khoa An Việt
			</footer>

		</div>
		<!-- /.hms-main -->

	</div>
	<!-- /.hms-wrapper -->

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

	

	<script>
		/* Live clock */
		function updateClock() {
			var now = new Date();
			var h = String(now.getHours()).padStart(2,'0');
			var m = String(now.getMinutes()).padStart(2,'0');
			var el = document.getElementById('tb-clock');
			if (el) el.textContent = h + ':' + m;
		}
		setInterval(updateClock, 1000);

		/* Active nav link highlight */
		(function () {
			var path = window.location.pathname.toLowerCase();
			document.querySelectorAll('.sb-nav .nav-link').forEach(function (link) {
				var href = link.getAttribute('href') || '';
				if (href && href !== '/' && path.startsWith(href.toLowerCase())) {
					link.classList.add('active');
				} else if (href === '/' && path === '/') {
					link.classList.add('active');
				}
			});
		})();
	</script>

	@await RenderSectionAsync("Scripts", required: false)

	@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
