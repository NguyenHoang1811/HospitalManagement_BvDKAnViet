				<a class="nav-link" asp-controller="Home" asp-action="Privacy">
					<i class="fas fa-calendar-check"></i> Đặt Lịch
				</a>

				<div class="sb-section">Lâm Sàng</div>

				<a class="nav-link" asp-controller="Patient" asp-action="Index">
					<i class="fas fa-user-injured"></i> Bệnh Nhân
				</a>

				<a class="nav-link" asp-controller="MedicalRecord" asp-action="Index">
					<i class="fas fa-file-medical"></i> Bệnh Án
				</a>

				<a class="nav-link" asp-controller="Medicine" asp-action="Index">
					<i class="fas fa-pills"></i> Thuốc
				</a>

				<div class="sb-section">Tổ Chức</div>

				<a class="nav-link" asp-controller="Department" asp-action="Index">
					<i class="fas fa-building-columns"></i> Khoa
				</a>

				<a class="nav-link" asp-controller="Doctor" asp-action="Index">
					<i class="fas fa-user-doctor"></i> Bác Sĩ
				</a>

				<a class="nav-link" asp-controller="Account" asp-action="Index">
					<i class="fas fa-user-gear"></i> Tài Khoản
				</a>

				<div class="sb-section">Phân Tích</div>

				<a class="nav-link" asp-controller="Home" asp-action="Privacy">
					<i class="fas fa-chart-line"></i> Thống Kê
				</a>

			</div><!-- /.sb-nav -->
			<!-- User profile -->
			<div class="sb-footer">
				<div class="sb-user">
					<div class="sb-avatar">
						@{
							var uname = User.Identity?.Name ??
							Context.Session.GetString("Username") ?? "ND";
							var initials = uname.Length >= 2
							? uname.Substring(0, 2).ToUpper()
							: uname.ToUpper();
						}
						@initials
					</div>
					<div>
						<div class="sb-user-name">@(Context.Session.GetString("Username") ?? "Người dùng")</div>
						<div class="sb-user-role">
							@(User.IsInRole("Admin") ? "Quản trị viên"
														: User.IsInRole("Doctor") ? "Bác sĩ"
														: User.IsInRole("Patient") ? "Bệnh nhân"
														: "Người dùng")
						</div>
					</div>
				</div>
				<a class="btn-logout"
				   asp-controller="Account"
				   asp-action="ChangePasswordSelf">
					<i class="fas fa-key"></i> Đổi mật khẩu
				</a>
				<a class="btn-logout"
