@model HospitalManagement_BvDKAnViet.WepApp.Models.StatisticsDTO.DoctorDashboardDto

@{
    ViewData["Title"] = "Home Page";
}

<div style="margin-bottom:16px;">
@if (TempData["SuccessMessage"] != null)
{
        <div class="alert alert-success">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["SuccessMessage"]
        </div>
}

@if (TempData["ErrorMessage"] != null)
{
        <div class="alert alert-danger">
            <i class="fas fa-circle-exclamation me-2"></i>
            @TempData["ErrorMessage"]
        </div>
}

</div>
<!-- ── KPI CARDS ── -->
<div class="row g-3 mb-4">

    <div class="col-6 col-lg-3">
        <div class="kpi-card">
            <div class="kpi-icon-wrap kpi-icon-teal"><i class="fas fa-calendar-check"></i></div>
            <div class="kpi-label">Tổng lịch hẹn</div>
            <div class="kpi-value">@Model.Total</div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="kpi-card">
            <div class="kpi-icon-wrap kpi-icon-green"><i class="fas fa-check-double"></i></div>
            <div class="kpi-label">Đã hoàn thành</div>
            <div class="kpi-value">@Model.Completed</div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="kpi-card">
            <div class="kpi-icon-wrap kpi-icon-warn"><i class="fas fa-clock"></i></div>
            <div class="kpi-label">Đang chờ</div>
            <div class="kpi-value">@Model.Pending</div>
        </div>
    </div>

    <div class="col-6 col-lg-3">
        <div class="kpi-card">
            <div class="kpi-icon-wrap" style="background:rgba(239,68,68,0.12);color:#dc2626;">
                <i class="fas fa-times-circle"></i>
            </div>
            <div class="kpi-label">Đã huỷ</div>
            <div class="kpi-value">@Model.Cancelled</div>
        </div>
    </div>

</div>

<div class="row g-4">

    <!-- ── CỘT TRÁI ── -->
    <div class="col-lg-8">

        <!-- KPI HIỆU SUẤT -->
        <div class="hms-card mb-4">
            <div class="hms-card-header">
                <div>
                    <div class="panel-title">KPI Hiệu suất</div>
                    <div class="panel-sub">Tổng hợp cá nhân</div>
                </div>
            </div>

            <div class="row g-3 px-2 pb-3">

                <!-- Tỷ lệ hoàn thành -->
                <div class="col-md-6">
                    <div class="perf-box">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small text-muted">Tỷ lệ hoàn thành</span>
                            <span class="fw-bold" style="color:#16a34a;">@Model.CompletionRate%</span>
                        </div>
                        <div class="perf-bar-bg">
                            <div class="perf-bar-fill bg-green"
                                 style="width:@Model.CompletionRate%"></div>
                        </div>
                        <div class="small text-muted mt-1">@Model.Completed / @Model.Total lịch</div>
                    </div>
                </div>

                <!-- Tỷ lệ huỷ -->
                <div class="col-md-6">
                    <div class="perf-box">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small text-muted">Tỷ lệ huỷ</span>
                            <span class="fw-bold" style="color:#dc2626;">@Model.CancellationRate%</span>
                        </div>
                        <div class="perf-bar-bg">
                            <div class="perf-bar-fill bg-red"
                                 style="width:@Model.CancellationRate%"></div>
                        </div>
                        <div class="small text-muted mt-1">@Model.Cancelled / @Model.Total lịch</div>
                    </div>
                </div>

                <!-- Tháng này -->
                <div class="col-md-4">
                    <div class="stat-mini">
                        <i class="fas fa-calendar-alt text-teal me-2"></i>
                        <div>
                            <div class="stat-mini-val">@Model.MonthTotal</div>
                            <div class="stat-mini-label">Lịch tháng này</div>
                        </div>
                    </div>
                </div>

                <!-- Tuần này -->
                <div class="col-md-4">
                    <div class="stat-mini">
                        <i class="fas fa-calendar-week text-blue me-2"></i>
                        <div>
                            <div class="stat-mini-val">
                                @Model.ThisWeekCount
                                @if (Model.WeekGrowth > 0)
                                {
                                    <span class="badge ms-1" style="background:rgba(34,197,94,0.15);color:#15803d;font-size:10px;">
                                        +@Model.WeekGrowth%
                                    </span>
                                }
                                else if (Model.WeekGrowth < 0)
                                {
                                    <span class="badge ms-1" style="background:rgba(239,68,68,0.15);color:#dc2626;font-size:10px;">
                                        @Model.WeekGrowth%
                                    </span>
                                }
                            </div>
                            <div class="stat-mini-label">Lịch tuần này</div>
                        </div>
                    </div>
                </div>

                <!-- Bệnh nhân -->
                <div class="col-md-4">
                    <div class="stat-mini">
                        <i class="fas fa-users text-purple me-2"></i>
                        <div>
                            <div class="stat-mini-val">@Model.TotalPatients</div>
                            <div class="stat-mini-label">Bệnh nhân đã khám</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- BIỂU ĐỒ THEO THÁNG -->
        <div class="hms-card mb-4">
            <div class="hms-card-header">
                <div>
                    <div class="panel-title">Lịch khám theo tháng</div>
                    <div class="panel-sub">Workload cả năm</div>
                </div>
                <select id="monthYear" class="form-select form-select-sm" style="width:100px;">
                    @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 2; y--)
                    {
                        <option value="@y">@y</option>
                    }
                </select>
            </div>
            <canvas id="monthChart" height="110"></canvas>
        </div>

        <!-- BIỂU ĐỒ THEO NGÀY -->
        <div class="hms-card">
            <div class="hms-card-header">
                <div>
                    <div class="panel-title">Lịch khám theo ngày</div>
                    <div class="panel-sub">Workload từng ngày trong tháng</div>
                </div>
                <div class="d-flex gap-2">
                    <select id="dayYear" class="form-select form-select-sm" style="width:90px;">
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 2; y--)
                        {
                            <option value="@y">@y</option>
                        }
                    </select>
                    <select id="dayMonth" class="form-select form-select-sm" style="width:110px;">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == DateTime.Today.Month)">Tháng @m</option>
                        }
                    </select>
                </div>
            </div>
            <canvas id="dayChart" height="100"></canvas>
        </div>

    </div>

    <!-- ── CỘT PHẢI ── -->
    <div class="col-lg-4">

        <!-- LỊCH HÔM NAY REALTIME -->
        <div class="hms-card mb-4">
            <div class="hms-card-header">
                <div>
                    <div class="panel-title">
                        <span class="live-dot me-1"></span> Lịch hôm nay
                    </div>
                    <div class="panel-sub">@DateTime.Today.ToString("dd/MM/yyyy")</div>
                </div>
                <span class="badge" style="background:rgba(45,212,191,0.15);color:#0d9488;font-size:11px;">
                    @Model.TodayCount lịch
                </span>
            </div>

            <div id="todayList" style="max-height:420px;overflow-y:auto;">
                @if (!Model.TodayAppointments.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-calendar-times fa-2x mb-2 opacity-50"></i>
                        <div class="small">Không có lịch hôm nay</div>
                    </div>
                }
                else
                {
                    foreach (var appt in Model.TodayAppointments)
                    {
                        var statusBg = appt.StatusName switch
                        {
                            "PENDING" => "rgba(251,191,36,0.12)",
                            "CONFIRMED" => "rgba(96,165,250,0.12)",
                            "COMPLETED" => "rgba(34,197,94,0.12)",
                            "CANCELLED" => "rgba(239,68,68,0.12)",
                            _ => "rgba(0,0,0,0.04)"
                        };
                        var statusColor = appt.StatusName switch
                        {
                            "PENDING" => "#92400e",
                            "CONFIRMED" => "#1d4ed8",
                            "COMPLETED" => "#15803d",
                            "CANCELLED" => "#b91c1c",
                            _ => "#64748b"
                        };
                        var statusLabel = appt.StatusName switch
                        {
                            "PENDING" => "Chờ xác nhận",
                            "CONFIRMED" => "Đã xác nhận",
                            "COMPLETED" => "Hoàn thành",
                            "CANCELLED" => "Đã huỷ",
                            _ => appt.StatusName
                        };

                        <div class="today-appt-item" id="appt-@appt.AppointmentId"
                             style="background:@statusBg;">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-semibold" style="font-size:14px;">
                                        @appt.PatientName
                                    </div>
                                    <div class="small text-muted mt-1">
                                        <i class="far fa-clock me-1"></i>@appt.AppointmentTime
                                    </div>
                                </div>
                                <span class="appt-status-badge"
                                      style="background:@statusBg;color:@statusColor;">
                                    @statusLabel
                                </span>
                            </div>

                            @if (appt.StatusName == "CONFIRMED" || appt.StatusName == "PENDING")
                            {
                                <div class="d-flex gap-2 mt-2"
                                     onclick="event.stopPropagation()">
                                    <button class="btn-appt-action btn-complete"
                                            onclick="completeAppt(@appt.AppointmentId, this)">
                                        <i class="fas fa-check me-1"></i> Hoàn thành
                                    </button>
                                    <button class="btn-appt-action btn-cancel"
                                            onclick="cancelAppt(@appt.AppointmentId, this)">
                                        <i class="fas fa-times me-1"></i> Huỷ
                                    </button>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <!-- LỊCH TUẦN -->
        <div class="hms-card">
            <div class="hms-card-header">
                <div>
                    <div class="panel-title">Lịch tuần này</div>
                    <div class="panel-sub">So sánh với tuần trước</div>
                </div>
            </div>
            <div id="weeklyContainer">
                <div class="text-center text-muted py-3 small">
                    <div class="spinner-border spinner-border-sm me-1"></div> Đang tải...
                </div>
            </div>
        </div>

    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        Chart.defaults.font.family = "'DM Sans', sans-serif";
        Chart.defaults.font.size   = 12;
        Chart.defaults.color       = '#64748b';

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        // ── BIỂU ĐỒ THEO THÁNG ──
        let monthChart;
        async function loadMonthChart(year) {
            const res  = await fetch(`/DoctorDashboard/ByMonth?year=${year}`);
            const data = await res.json();

            if (monthChart) monthChart.destroy();

            monthChart = new Chart(document.getElementById('monthChart'), {
                type: 'bar',
                data: {
                    labels: data.map(x => x.label),
                    datasets: [
                        {
                            label: 'Tổng lịch',
                            data: data.map(x => x.total),
                            backgroundColor: 'rgba(45,212,191,0.2)',
                            borderColor: '#2dd4bf',
                            borderWidth: 2,
                            borderRadius: 5,
                            order: 2
                        },
                        {
                            label: 'Hoàn thành',
                            type: 'line',
                            data: data.map(x => x.completed),
                            borderColor: '#22c55e',
                            backgroundColor: 'rgba(34,197,94,0.08)',
                            tension: 0.4,
                            fill: true,
                            pointRadius: 3,
                            order: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top' } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        document.getElementById('monthYear').addEventListener('change', function () {
            loadMonthChart(this.value);
        });

        // ── BIỂU ĐỒ THEO NGÀY ──
        let dayChart;
        async function loadDayChart(year, month) {
            const res  = await fetch(`/DoctorDashboard/ByDay?year=${year}&month=${month}`);
            const data = await res.json();

            if (dayChart) dayChart.destroy();

            dayChart = new Chart(document.getElementById('dayChart'), {
                type: 'bar',
                data: {
                    labels: data.map(x => x.label),
                    datasets: [{
                        label: 'Số lịch',
                        data: data.map(x => x.total),
                        backgroundColor: data.map(x => {
                            const today = new Date().getDate();
                            return x.day === today
                                ? 'rgba(45,212,191,0.7)'
                                : 'rgba(96,165,250,0.3)';
                        }),
                        borderColor: data.map(x => {
                            const today = new Date().getDate();
                            return x.day === today ? '#2dd4bf' : '#60a5fa';
                        }),
                        borderWidth: 1.5,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.04)' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        document.getElementById('dayYear').addEventListener('change', reloadDayChart);
        document.getElementById('dayMonth').addEventListener('change', reloadDayChart);

        function reloadDayChart() {
            const year  = document.getElementById('dayYear').value;
            const month = document.getElementById('dayMonth').value;
            loadDayChart(year, month);
        }

        // ── LỊCH TUẦN ──
        async function loadWeekly() {
            const res  = await fetch('/DoctorDashboard/Weekly');
            const data = await res.json();

            const container = document.getElementById('weeklyContainer');

            const growthColor = data.weekGrowth >= 0 ? '#15803d' : '#dc2626';
            const growthIcon  = data.weekGrowth >= 0 ? 'fa-arrow-up' : 'fa-arrow-down';

            let html = `
                <div class="d-flex justify-content-around text-center py-3 border-bottom">
                    <div>
                        <div style="font-size:22px;font-weight:700;color:#0f2744;">
                            ${data.thisWeekCount}
                        </div>
                        <div class="small text-muted">Tuần này</div>
                    </div>
                    <div style="border-left:1px solid #f1f5f9;"></div>
                    <div>
                        <div style="font-size:22px;font-weight:700;color:#64748b;">
                            ${data.lastWeekCount}
                        </div>
                        <div class="small text-muted">Tuần trước</div>
                    </div>
                    <div style="border-left:1px solid #f1f5f9;"></div>
                    <div>
                        <div style="font-size:18px;font-weight:700;color:${growthColor};">
                            <i class="fas ${growthIcon} me-1" style="font-size:13px;"></i>
                            ${Math.abs(data.weekGrowth)}%
                        </div>
                        <div class="small text-muted">Tăng/giảm</div>
                    </div>
                </div>
                <div class="p-2">`;

            (data.days ?? []).forEach(d => {
                const barW = data.thisWeekCount > 0
                    ? Math.round(d.total / Math.max(...data.days.map(x => x.total), 1) * 100)
                    : 0;

                html += `
                    <div class="d-flex align-items-center gap-2 py-1">
                        <span style="width:72px;font-size:12px;color:#64748b;">${d.label}</span>
                        <div style="flex:1;height:6px;background:#f1f5f9;border-radius:3px;">
                            <div style="width:${barW}%;height:100%;background:#2dd4bf;border-radius:3px;transition:width 0.5s;"></div>
                        </div>
                        <span style="width:20px;font-size:12px;font-weight:600;color:#0f2744;text-align:right;">${d.total}</span>
                    </div>`;
            });

            html += '</div>';
            container.innerHTML = html;
        }

        // ── NÚT HOÀN THÀNH / HUỶ ──
        async function completeAppt(id, btn) {
            if (!confirm('Xác nhận hoàn thành lịch hẹn này?')) return;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            const res = await fetch(`/DoctorDashboard/Complete?id=${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });

            const result = await res.json();

            if (result.success) {
                // Cập nhật UI không cần reload
                const card = document.getElementById(`appt-${id}`);
                card.style.background = 'rgba(34,197,94,0.12)';
                card.querySelector('.appt-status-badge').textContent = 'Hoàn thành';
                card.querySelector('.appt-status-badge').style.color = '#15803d';
                card.querySelector('.d-flex.gap-2.mt-2')?.remove();
            } else {
                alert(result.message ?? 'Lỗi khi cập nhật');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-check me-1"></i> Hoàn thành';
            }
        }

        async function cancelAppt(id, btn) {
            if (!confirm('Xác nhận huỷ lịch hẹn này?')) return;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            const res = await fetch(`/DoctorDashboard/Cancel?id=${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });

            const result = await res.json();

            if (result.success) {
                const card = document.getElementById(`appt-${id}`);
                card.style.background = 'rgba(239,68,68,0.08)';
                card.querySelector('.appt-status-badge').textContent = 'Đã huỷ';
                card.querySelector('.appt-status-badge').style.color = '#b91c1c';
                card.querySelector('.d-flex.gap-2.mt-2')?.remove();
            } else {
                alert(result.message ?? 'Lỗi khi cập nhật');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-times me-1"></i> Huỷ';
            }
        }

        // ── KHỞI CHẠY ──
        const now = new Date();
        loadMonthChart(now.getFullYear());
        loadDayChart(now.getFullYear(), now.getMonth() + 1);
        loadWeekly();

        // Auto-refresh lịch hôm nay mỗi 60s
        setInterval(async () => {
            const res  = await fetch('/DoctorDashboard/Today');
            const data = await res.json();
            // Chỉ update số lịch, không render lại cả list để tránh mất trạng thái UI
            console.log('Today refresh:', data.length, 'appointments');
        }, 60000);
    </script>
}

<style>
    /* ── KPI BAR ── */
    .perf-box {
        padding: 12px 16px;
        background: #f8fafc;
        border-radius: 10px;
    }

    .perf-bar-bg {
        height: 8px;
        background: #e2e8f0;
        border-radius: 4px;
        overflow: hidden;
    }

    .perf-bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.8s ease;
    }

    .bg-green {
        background: #22c55e;
    }

    .bg-red {
        background: #ef4444;
    }

    /* ── STAT MINI ── */
    .stat-mini {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: #f8fafc;
        border-radius: 10px;
    }

        .stat-mini i {
            font-size: 20px;
        }

    .stat-mini-val {
        font-size: 20px;
        font-weight: 700;
        color: #0f2744;
        line-height: 1;
    }

    .stat-mini-label {
        font-size: 11px;
        color: #64748b;
        margin-top: 2px;
    }

    .text-blue {
        color: #60a5fa !important;
    }

    .text-purple {
        color: #a78bfa !important;
    }

    /* ── TODAY LIST ── */
    .today-appt-item {
        padding: 12px 14px;
        border-radius: 10px;
        margin: 6px 10px;
        border: 1px solid rgba(0,0,0,0.04);
        transition: all 0.2s;
    }

        .today-appt-item:hover {
            transform: translateX(3px);
        }

    .appt-status-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        white-space: nowrap;
    }

    /* ── ACTION BUTTONS ── */
    .btn-appt-action {
        flex: 1;
        padding: 5px 0;
        border-radius: 7px;
        border: none;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-complete {
        background: rgba(34,197,94,0.15);
        color: #15803d;
    }

        .btn-complete:hover {
            background: #22c55e;
            color: white;
        }

    .btn-cancel {
        background: rgba(239,68,68,0.12);
        color: #dc2626;
    }

        .btn-cancel:hover {
            background: #ef4444;
            color: white;
        }

    /* ── LIVE DOT ── */
    .live-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: #22c55e;
        border-radius: 50%;
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(1.3);
        }
    }
</style>

