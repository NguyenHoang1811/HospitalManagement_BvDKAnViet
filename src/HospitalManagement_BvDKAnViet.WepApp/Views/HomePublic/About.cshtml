@{
    ViewData["Title"] = "Về chúng tôi";
}

<!-- ================= HERO BANNER ================= -->
<div class="about-hero position-relative">
    <div class="hero-overlay"></div>
    <div class="container position-relative text-center text-white" style="z-index: 2; padding-top: 80px; padding-bottom: 80px;">
        <h1 class="fw-bold mb-3 display-4">Bệnh viện Đa khoa An Việt</h1>
        <p class="lead" style="max-width: 700px; margin: 0 auto; color: #e2e8f0;">
            Hơn 15 năm nỗ lực không ngừng vì sức khỏe cộng đồng, mang đến dịch vụ y tế chuẩn quốc tế bằng trái tim tận tâm và trí tuệ Việt.
        </p>
    </div>
</div>

<!-- ================= CÂU CHUYỆN LỊCH SỬ ================= -->
<div class="container mt-5 pt-4">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <div class="position-relative">
                <!-- Dùng ảnh từ Unsplash để fake dữ liệu nhìn cho sinh động, bạn có thể thay bằng ảnh thật -->
                <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                     alt="Về Bệnh viện An Việt"
                     class="img-fluid rounded-4 shadow-lg about-main-img">

                <div class="experience-badge shadow">
                    <span class="fs-2 fw-bold text-teal">15+</span><br>
                    <span class="fw-medium text-navy">Năm Kinh Nghiệm</span>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <h6 class="text-teal text-uppercase fw-bold mb-2">Câu chuyện của chúng tôi</h6>
            <h2 class="section-title mb-4">Chăm sóc sức khỏe bằng cả trái tim</h2>
            <p class="text-muted" style="line-height: 1.8; font-size: 15.5px;">
                Được thành lập vào năm 2010, Bệnh viện Đa khoa An Việt khởi nguồn từ khát vọng mang đến một môi trường khám chữa bệnh thân thiện, chất lượng và an toàn tuyệt đối cho người dân Việt Nam.
            </p>
            <p class="text-muted" style="line-height: 1.8; font-size: 15.5px;">
                Trải qua hơn một thập kỷ phát triển, chúng tôi tự hào đã quy tụ được đội ngũ Giáo sư, Tiến sĩ, Bác sĩ chuyên khoa đầu ngành. Kết hợp cùng hệ thống trang thiết bị y tế hiện đại bậc nhất được nhập khẩu từ Mỹ, Đức, Nhật Bản... An Việt cam kết cung cấp phác đồ điều trị hiệu quả và cá nhân hóa cho từng bệnh nhân.
            </p>

            <div class="d-flex align-items-center mt-4 gap-3">
                <div class="bg-teal-light p-3 rounded-circle text-teal d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                    <i class="fas fa-check-circle fs-4"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-1 text-navy">Cơ sở vật chất chuẩn 5 sao</h6>
                    <span class="text-muted" style="font-size: 14px;">Môi trường vô khuẩn, không gian thân thiện.</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ================= TẦM NHÌN & SỨ MỆNH ================= -->
<div class="container mt-5 pt-5">
    <div class="row g-4 text-center">
        <!-- Tầm nhìn -->
        <div class="col-md-4">
            <div class="card core-value-card h-100 p-4 border-0 shadow-sm">
                <div class="icon-wrapper mb-3 mx-auto">
                    <i class="fas fa-eye"></i>
                </div>
                <h4 class="fw-bold text-navy mb-3">Tầm Nhìn</h4>
                <p class="text-muted mb-0">Trở thành hệ thống y tế tư nhân hàng đầu Việt Nam, đạt chuẩn chất lượng quốc tế JCI trong việc khám và điều trị bệnh.</p>
            </div>
        </div>

        <!-- Sứ mệnh -->
        <div class="col-md-4">
            <div class="card core-value-card h-100 p-4 border-0 shadow-sm">
                <div class="icon-wrapper mb-3 mx-auto" style="background: #e0f2fe; color: #0284c7;">
                    <i class="fas fa-heartbeat"></i>
                </div>
                <h4 class="fw-bold text-navy mb-3">Sứ Mệnh</h4>
                <p class="text-muted mb-0">Mang đến dịch vụ chăm sóc sức khỏe toàn diện, an toàn và hiệu quả với chi phí hợp lý nhất cho cộng đồng.</p>
            </div>
        </div>

        <!-- Giá trị cốt lõi -->
        <div class="col-md-4">
            <div class="card core-value-card h-100 p-4 border-0 shadow-sm">
                <div class="icon-wrapper mb-3 mx-auto" style="background: #fef08a; color: #ca8a04;">
                    <i class="fas fa-star"></i>
                </div>
                <h4 class="fw-bold text-navy mb-3">Giá Trị Cốt Lõi</h4>
                <p class="text-muted mb-0">Tận tâm vì người bệnh - Chuyên môn xuất sắc - Chính trực - Đổi mới sáng tạo không ngừng.</p>
            </div>
        </div>
    </div>
</div>

<!-- ================= KHỐI THỐNG KÊ (Đồng bộ với Homepage) ================= -->
<div class="container mt-5 pt-5">
    <div class="stats-wrapper row text-center g-4">
        <div class="col-md-3 col-6 stat-item">
            <h3>15+</h3>
            <p>Năm Kinh Nghiệm</p>
        </div>
        <div class="col-md-3 col-6 stat-item">
            <h3>500+</h3>
            <p>Y Bác Sĩ & Chuyên Gia</p>
        </div>
        <div class="col-md-3 col-6 stat-item">
            <h3>1M+</h3>
            <p>Khách Hàng Tin Tưởng</p>
        </div>
        <div class="col-md-3 col-6 stat-item">
            <h3>50+</h3>
            <p>Phòng Khám Hiện Đại</p>
        </div>
    </div>
</div>

<!-- ================= LÝ DO CHỌN CHÚNG TÔI ================= -->
<!-- ================= LÝ DO CHỌN CHÚNG TÔI ================= -->
<div class="bg-light mt-5 py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h6 class="text-teal text-uppercase fw-bold mb-2">Ưu điểm vượt trội</h6>
            <h2 class="section-title">Tại sao chọn Bệnh viện An Việt?</h2>
        </div>

        <div class="row g-4">
            <div class="col-lg-6">
                <div class="d-flex gap-3 mb-4 feature-box p-3 rounded-4 bg-white shadow-sm transition-all">
                    <div class="text-teal mt-1"><i class="fas fa-user-md fs-3"></i></div>
                    <div>
                        <h5 class="fw-bold text-navy">Đội ngũ chuyên gia hàng đầu</h5>
                        <p class="text-muted mb-0">Hội tụ đội ngũ bác sĩ giàu kinh nghiệm, từng tu nghiệp tại nước ngoài và công tác tại các bệnh viện tuyến đầu Trung ương.</p>
                    </div>
                </div>
                <div class="d-flex gap-3 mb-4 feature-box p-3 rounded-4 bg-white shadow-sm transition-all">
                    <div class="text-teal mt-1"><i class="fas fa-microscope fs-3"></i></div>
                    <div>
                        <h5 class="fw-bold text-navy">Trang thiết bị y tế tân tiến</h5>
                        <p class="text-muted mb-0">Sở hữu hệ thống MRI 3.0 Tesla, CT 128 lát cắt, phòng mổ vô khuẩn áp lực dương chuẩn quốc tế giúp chẩn đoán chính xác tuyệt đối.</p>
                    </div>
                </div>
                <div class="d-flex gap-3 feature-box p-3 rounded-4 bg-white shadow-sm transition-all">
                    <div class="text-teal mt-1"><i class="fas fa-clock fs-3"></i></div>
                    <div>
                        <h5 class="fw-bold text-navy">Dịch vụ chuyên nghiệp 24/7</h5>
                        <p class="text-muted mb-0">Quy trình khám chữa bệnh tinh gọn, không chờ đợi. Trực cấp cứu và hỗ trợ khách hàng liên tục 24/7.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 text-center">
                <!-- Đã thay đổi link ảnh tại đây -->
                <img src="https://images.unsplash.com/photo-1581594693702-fbdc51b2763b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                     alt="Tại sao chọn chúng tôi"
                     class="img-fluid rounded-4 shadow-sm" style="height: 100%; object-fit: cover; max-height: 400px; width: 100%;">
            </div>
        </div>
    </div>
</div>

<!-- ================= CTA (CALL TO ACTION) ================= -->
<div class="container my-5 py-4 text-center">
    <h3 class="fw-bold text-navy mb-3">Bạn cần tư vấn sức khỏe?</h3>
    <p class="text-muted mb-4 fs-5">Hãy để đội ngũ y bác sĩ An Việt chăm sóc bạn và gia đình ngay hôm nay.</p>
    <a asp-controller="Appointment" asp-action="Create" class="btn btn-book-lg px-5 py-3 fs-5">
        <i class="fas fa-calendar-alt me-2"></i> Đặt lịch khám ngay
    </a>
</div>

<!-- ================= CSS CHO TRANG ABOUT ================= -->
<style>
    /* MÀU SẮC DỰA TRÊN LAYOUT CHUNG */
    :root {
        --navy: #0f2744;
        --teal: #0d9488;
        --teal-light: #ccfbf1;
    }

    .text-navy {
        color: var(--navy) !important;
    }

    .text-teal {
        color: var(--teal) !important;
    }

    .bg-teal-light {
        background-color: var(--teal-light) !important;
    }

    /* TITLE CHUNG */
    .section-title {
        color: var(--navy);
        font-weight: 700;
        font-size: 28px;
    }

    /* HERO BANNER */
    .about-hero {
        background-image: url('https://images.unsplash.com/photo-1586773860418-d37222d8fce3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-position: center;
        background-attachment: fixed; /* Hiệu ứng parallax nhẹ */
        border-radius: 0 0 40px 40px;
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(90deg, rgba(15,39,68,0.9) 0%, rgba(13,148,136,0.8) 100%);
        z-index: 1;
    }

    /* ẢNH & BADGE TRONG PHẦN CÂU CHUYỆN */
    .about-main-img {
        object-fit: cover;
        height: 450px;
        width: 100%;
    }

    .experience-badge {
        position: absolute;
        bottom: -20px;
        right: -20px;
        background: white;
        padding: 20px 30px;
        border-radius: 16px;
        border-left: 5px solid var(--teal);
        text-align: center;
    }

    /* CORE VALUE CARDS */
    .core-value-card {
        border-radius: 20px;
        transition: transform 0.3s ease;
        background: white;
    }

        .core-value-card:hover {
            transform: translateY(-10px);
        }

    .icon-wrapper {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: var(--teal-light);
        color: var(--teal);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }

    /* KHỐI THỐNG KÊ (Copy từ layout trang chủ) */
    .stats-wrapper {
        background: linear-gradient(135deg, #0f2744 0%, #1a365d 100%);
        border-radius: 24px;
        padding: 40px 20px;
        box-shadow: 0 10px 30px rgba(15, 39, 68, 0.15);
        margin: 0;
    }

    .stat-item h3 {
        color: #2dd4bf;
        font-weight: 800;
        font-size: clamp(28px, 4vw, 40px); /* Tự động thu nhỏ trên điện thoại */
        margin-bottom: 5px;
    }

    .stat-item p {
        color: #e2e8f0;
        font-size: 15px;
        margin-bottom: 0;
        font-weight: 500;
    }

    /* FEATURE BOX */
    .transition-all {
        transition: all 0.3s ease;
    }

    .feature-box:hover {
        transform: translateX(10px);
        border-left: 4px solid var(--teal);
    }

    /* NÚT ĐẶT LỊCH LỚN */
    .btn-book-lg {
        background-color: var(--teal);
        color: white;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(13, 148, 136, 0.4);
    }

        .btn-book-lg:hover {
            background-color: #0f766e;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(13, 148, 136, 0.5);
        }

    /* Reponsive cho điện thoại */
    @@media (max-width: 768px) {
        .experience-badge

    {
        position: relative;
        bottom: auto;
        right: auto;
        margin-top: -30px;
        width: 80%;
        margin-left: auto;
        margin-right: auto;
        z-index: 2;
    }

    }
</style>