@model IEnumerable<HospitalManagement_BvDKAnViet.WepApp.Models.DoctorDTO.DoctorDto>

@{
    ViewData["Title"] = "Trang chủ";
}

<!-- ================= BANNER / SLIDER ================= -->
<div class="container mt-4 mb-5">
    <div id="homeSlider" class="carousel slide shadow-lg hero-slider" data-bs-ride="carousel" data-bs-interval="4000">
        <!-- Indicators -->
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="2"></button>
        </div>

        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" class="d-block w-100 slider-img" alt="Banner 1">
                <div class="carousel-caption d-none d-md-block bg-glass">
                    <h3 class="fw-bold text-navy">Đặt lịch dễ dàng, tiện lợi</h3>
                    <p class="mb-0 text-dark">Hệ thống đặt lịch trực tuyến 24/7, tối ưu thời gian chờ đợi.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1586773860418-d37222d8fce3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" class="d-block w-100 slider-img" alt="Banner 2">
                <div class="carousel-caption d-none d-md-block bg-glass">
                    <h3 class="fw-bold text-navy">Cơ sở vật chất hiện đại</h3>
                    <p class="mb-0 text-dark">Trang thiết bị y tế tân tiến, không gian khám chữa bệnh chuẩn 5 sao.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1579684385127-1ef15d508118?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" class="d-block w-100 slider-img" alt="Banner 3">
                <div class="carousel-caption d-none d-md-block bg-glass">
                    
                    <h3 class="fw-bold text-navy">Chăm sóc sức khỏe toàn diện</h3>
                    <p class="mb-0 text-dark">Đội ngũ y bác sĩ đầu ngành luôn sẵn sàng vì sức khỏe của bạn.</p>
                </div>
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#homeSlider" data-bs-slide="prev">
            <div class="nav-btn"><i class="fas fa-chevron-left"></i></div>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#homeSlider" data-bs-slide="next">
            <div class="nav-btn"><i class="fas fa-chevron-right"></i></div>
        </button>
    </div>
</div>

<!-- ================= DỊCH VỤ NỔI BẬT ================= -->
<div class="bg-light py-5 mb-5">
    <div class="container">
        <div class="text-center mb-5">
            <h6 class="text-teal text-uppercase fw-bold mb-2">Dịch vụ của chúng tôi</h6>
            <h2 class="section-title">Chuyên khoa nổi bật</h2>
        </div>

        <div class="row g-4">

            <!-- 1. Thận (Được thay thế và đưa lên đầu) -->
            <div class="col-lg-3 col-md-6">
                <div class="service-card card p-4 h-100 text-center shadow-sm">
                    <div class="icon-box mb-3 mx-auto text-danger bg-danger-light">
                        <i class="fas fa-tint fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-navy">Thận - Tiết niệu</h5>
                    <p class="text-muted small mb-0">Chẩn đoán và điều trị chuyên sâu các bệnh lý về thận và đường tiết niệu.</p>
                </div>
            </div>

            <!-- 2. Tim mạch -->
            <div class="col-lg-3 col-md-6">
                <div class="service-card card p-4 h-100 text-center shadow-sm">
                    <div class="icon-box mb-3 mx-auto text-teal bg-teal-light">
                        <i class="fas fa-heartbeat fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-navy">Tim mạch</h5>
                    <p class="text-muted small mb-0">Chẩn đoán và điều trị các bệnh lý tim mạch bằng công nghệ cao.</p>
                </div>
            </div>

            <!-- 3. Thần kinh -->
            <div class="col-lg-3 col-md-6">
                <div class="service-card card p-4 h-100 text-center shadow-sm">
                    <div class="icon-box mb-3 mx-auto text-primary bg-primary-light">
                        <i class="fas fa-brain fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-navy">Thần kinh</h5>
                    <p class="text-muted small mb-0">Khám và điều trị chuyên sâu các bệnh lý nội thần kinh.</p>
                </div>
            </div>

            <!-- 4. Nhi khoa -->
            <div class="col-lg-3 col-md-6">
                <div class="service-card card p-4 h-100 text-center shadow-sm">
                    <div class="icon-box mb-3 mx-auto text-warning bg-warning-light">
                        <i class="fas fa-baby fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-navy">Nhi khoa</h5>
                    <p class="text-muted small mb-0">Chăm sóc sức khỏe toàn diện cho trẻ sơ sinh và trẻ nhỏ.</p>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ================= DOCTOR LIST ================= -->
<div class="container mb-5 pb-3">
    <div class="text-center mb-5">
        <h6 class="text-teal text-uppercase fw-bold mb-2">Đội ngũ của chúng tôi</h6>
        <h2 class="section-title">Bác sĩ chuyên gia</h2>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var doc in Model.Take(6))
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card doctor-card h-100">
                        <div class="doctor-img-wrapper">
                            <img src="@Url.Content(doc.DoctorImage ?? "~/img/doctor/default-doctor.png")"
                                 class="card-img-top doctor-img" alt="@doc.Name"
                                 onerror="this.onerror=null;this.src='/img/default-doctor.png';" />
                        </div>

                        <div class="card-body text-center doctor-info d-flex flex-column">
                            <h5 class="doctor-name">@doc.Name</h5>
                            <div class="mb-3">
                                <span class="badge doctor-specialty">@doc.Specialty</span>
                            </div>

                            <div class="mt-auto d-flex justify-content-center gap-2">
                                @if (User.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    <!-- Nếu đã đăng nhập: Chuyển hướng bình thường -->
                                    <a class="btn btn-book btn-action flex-grow-1"
                                       asp-controller="HomePublic"
                                       asp-action="BookAppointment"
                                       asp-route-doctorId="@doc.DoctorId">
                                        <i class="fas fa-calendar-plus me-1"></i> Đặt lịch
                                    </a>
                                }
                                else
                                {
                                    <!-- Nếu CHƯA đăng nhập: Mở pop-up thông báo -->
                                    <button type="button" class="btn btn-book btn-action flex-grow-1" data-bs-toggle="modal" data-bs-target="#loginRequireModal">
                                        <i class="fas fa-calendar-plus me-1"></i> Đặt lịch
                                    </button>
                                }

                                <a class="btn btn-outline-secondary btn-action flex-grow-1"
                                   asp-controller="HomePublic"
                                   asp-action="DoctorDetail"
                                   asp-route-id="@doc.DoctorId">
                                    Chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <img src="~/img/no-data.png" alt="No data" style="width: 150px; opacity: 0.5;" class="mb-3" onerror="this.style.display='none'">
                <p class="text-muted fs-5">Hiện chưa có dữ liệu bác sĩ.</p>
            </div>
        }
    </div>

    <div class="text-center mt-5">
        <a asp-controller="HomePublic" asp-action="Doctor" class="btn btn-outline-teal px-4 py-2 rounded-pill fw-medium">
            Xem tất cả bác sĩ <i class="fas fa-arrow-right ms-2"></i>
        </a>
    </div>
</div>

<!-- ================= QUY TRÌNH KHÁM BỆNH ================= -->
<div class="bg-navy text-white py-5 mb-5 process-section">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h6 class="text-teal text-uppercase fw-bold mb-2">Đơn giản - Nhanh chóng</h6>
            <h2 class="section-title text-white">Quy trình đặt khám</h2>
        </div>

        <div class="row g-4 text-center">
            <div class="col-lg-3 col-md-6 position-relative step-item">
                <div class="step-icon mx-auto mb-3"><i class="fas fa-calendar-check"></i></div>
                <h5 class="fw-bold">1. Đặt lịch khám</h5>
                <p class="text-white-50 small">Chọn bác sĩ, ngày giờ trên website.</p>
                <div class="step-arrow d-none d-lg-block"><i class="fas fa-chevron-right text-teal opacity-50 fs-3"></i></div>
            </div>
            <div class="col-lg-3 col-md-6 position-relative step-item">
                <div class="step-icon mx-auto mb-3"><i class="fas fa-hospital-user"></i></div>
                <h5 class="fw-bold">2. Đến bệnh viện</h5>
                <p class="text-white-50 small">Làm thủ tục nhanh tại quầy lễ tân.</p>
                <div class="step-arrow d-none d-lg-block"><i class="fas fa-chevron-right text-teal opacity-50 fs-3"></i></div>
            </div>
            <div class="col-lg-3 col-md-6 position-relative step-item">
                <div class="step-icon mx-auto mb-3"><i class="fas fa-stethoscope"></i></div>
                <h5 class="fw-bold">3. Khám lâm sàng</h5>
                <p class="text-white-50 small">Bác sĩ chuyên khoa trực tiếp tư vấn.</p>
                <div class="step-arrow d-none d-lg-block"><i class="fas fa-chevron-right text-teal opacity-50 fs-3"></i></div>
            </div>
            <div class="col-lg-3 col-md-6 step-item">
                <div class="step-icon mx-auto mb-3"><i class="fas fa-notes-medical"></i></div>
                <h5 class="fw-bold">4. Nhận kết quả</h5>
                <p class="text-white-50 small">Lấy đơn thuốc và theo dõi tại nhà.</p>
            </div>
        </div>
    </div>
</div>

<!-- ================= STATISTICS ================= -->
<div class="container mb-5">
    <div class="stats-wrapper row text-center g-4">
        <div class="col-md-4 stat-item">
            <h3>100+</h3>
            <p>Bác sĩ chuyên môn cao</p>
        </div>
        <div class="col-md-4 stat-item position-relative">
            <div class="d-none d-md-block position-absolute top-50 start-0 translate-middle-y border-start border-light w-100" style="height: 60%; opacity: 0.2;"></div>
            <div class="d-none d-md-block position-absolute top-50 end-0 translate-middle-y border-end border-light w-100" style="height: 60%; opacity: 0.2;"></div>
            <h3>10.000+</h3>
            <p>Bệnh nhân tin tưởng</p>
        </div>
        <div class="col-md-4 stat-item">
            <h3>24/7</h3>
            <p>Hỗ trợ liên tục</p>
        </div>
    </div>

</div>
<!-- ================= MODAL YÊU CẦU ĐĂNG NHẬP ================= -->
<div class="modal fade" id="loginRequireModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg" style="border-radius: 20px; border: none;">

            <div class="modal-header border-0 pb-0 justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>

            <div class="modal-body text-center px-4 pb-5 pt-0">
                <div class="mb-3">
                    <!-- Icon ổ khóa -->
                    <div class="mx-auto bg-teal-light text-teal d-flex align-items-center justify-content-center" style="width: 70px; height: 70px; border-radius: 50%;">
                        <i class="fas fa-user-lock fs-1"></i>
                    </div>
                </div>

                <h5 class="fw-bold text-navy mb-3">Yêu cầu đăng nhập</h5>
                <p class="text-muted mb-4" style="font-size: 14.5px;">
                    Bạn cần đăng nhập vào hệ thống để có thể tự đặt lịch khám trực tuyến. Hoặc gọi ngay cho tổng đài để được hỗ trợ đặt lịch nhanh nhất!
                </p>

                <div class="d-flex flex-column gap-3 px-3">
                    <a href="/Auth/Login" class="btn btn-teal py-2 rounded-pill fw-medium">
                        <i class="fas fa-sign-in-alt me-2"></i> Chuyển đến Đăng nhập
                    </a>
                    <a href="tel:19001234" class="btn btn-outline-orange py-2 rounded-pill fw-medium">
                        <i class="fas fa-phone-alt me-2"></i> Gọi tổng đài 1900 1234
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Thêm một chút CSS nhỏ cho nút Gọi tổng đài -->
<style>
    .bg-teal-light {
        background-color: #ccfbf1 !important;
    }

    .btn-outline-orange {
        color: #f97316;
        border: 2px solid #f97316;
        background: transparent;
        transition: all 0.3s ease;
    }

        .btn-outline-orange:hover {
            background: #f97316;
            color: white;
        }
</style>
<!-- ================= STYLE ================= -->
<style>
    /* VARIABLES (Dùng chung nếu chưa có) */
    :root {
        --navy: #0f2744;
        --teal: #0d9488;
        --teal-light: #ccfbf1;
    }

    .text-navy {
        color: var(--navy) !important;
    }

    .bg-navy {
        background-color: var(--navy) !important;
    }

    .text-teal {
        color: var(--teal) !important;
    }

    /* SLIDER BO GÓC CAO CẤP */
    .hero-slider {
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
    }

    .slider-img {
        width: 100%;
        height: clamp(350px, 45vw, 600px);
        object-fit: cover;
        object-position: center;
        image-rendering: auto;
    }

    /* Khung text nổi trên banner */
    .bg-glass {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        padding: 20px 40px;
        border-radius: 16px;
        bottom: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        display: inline-block;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Nút Next/Prev của Slider */
    .nav-btn {
        background: rgba(255,255,255,0.9);
        color: var(--navy);
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

    .carousel-control-prev:hover .nav-btn,
    .carousel-control-next:hover .nav-btn {
        background: var(--teal);
        color: white;
    }

    .carousel-control-prev, .carousel-control-next {
        opacity: 1;
    }

    /* TIÊU ĐỀ SECTION */
    .section-title {
        color: #0f2744;
        font-weight: 700;
        font-size: 32px;
        position: relative;
        padding-bottom: 15px;
        display: inline-block;
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background-color: var(--teal);
            border-radius: 2px;
        }

    /* DỊCH VỤ CARD */
    .service-card {
        border: 1px solid rgba(0,0,0,0.03);
        border-radius: 20px;
        transition: 0.3s;
        background: white;
    }

        .service-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.06) !important;
        }

    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bg-primary-light {
        background: #e0f2fe;
    }

    .bg-warning-light {
        background: #fef3c7;
    }

    .bg-danger-light {
        background: #fee2e2;
    }

    /* DOCTOR CARD */
    .doctor-card {
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    }

        .doctor-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        }

    .doctor-img-wrapper {
        background-color: #f8fafc;
        border-bottom: 1px solid rgba(0,0,0,0.03);
    }

    .doctor-img {
        height: 280px;
        width: 100%;
        object-fit: cover;
        object-position: top center;
    }

    .doctor-info {
        padding: 24px 20px;
    }

    .doctor-name {
        color: #1e293b;
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .doctor-specialty {
        background-color: var(--teal-light);
        color: var(--teal);
        font-size: 14px;
        font-weight: 500;
        padding: 6px 14px;
        border-radius: 20px;
    }

    .btn-action {
        border-radius: 8px;
        font-weight: 500;
        padding: 8px 12px;
        transition: all 0.2s ease;
    }

    .btn-book {
        background-color: var(--teal);
        border-color: var(--teal);
        color: white;
    }

        .btn-book:hover {
            background-color: #0f766e;
            border-color: #0f766e;
            color: white;
        }

    .btn-outline-secondary {
        color: #64748b;
        border-color: #cbd5e1;
    }

        .btn-outline-secondary:hover {
            background-color: #f1f5f9;
            color: #334155;
            border-color: #94a3b8;
        }

    .btn-outline-teal {
        border: 2px solid var(--teal);
        color: var(--teal);
        transition: 0.3s;
    }

        .btn-outline-teal:hover {
            background: var(--teal);
            color: white;
        }

    /* QUY TRÌNH KHÁM BỆNH */
    .process-section {
        border-radius: 40px;
        margin-left: 15px;
        margin-right: 15px;
    }

    .step-icon {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        color: var(--teal);
        border: 2px dashed rgba(13,148,136,0.5);
        transition: 0.3s;
    }

    .step-item:hover .step-icon {
        background: var(--teal);
        color: white;
        border-style: solid;
        transform: scale(1.1);
    }

    .step-arrow {
        position: absolute;
        top: 25px;
        right: -15px;
    }

    /* STATISTICS SECTION */
    .stats-wrapper {
        background: linear-gradient(135deg, #0f2744 0%, #1a365d 100%);
        border-radius: 24px;
        padding: 40px 20px;
        box-shadow: 0 10px 30px rgba(15, 39, 68, 0.15);
        margin: 0;
    }

    .stat-item h3 {
        color: #2dd4bf;
        font-weight: 800;
        font-size: 40px;
        margin-bottom: 8px;
    }

    .stat-item p {
        color: #e2e8f0;
        font-size: 16px;
        margin-bottom: 0;
        font-weight: 500;
    }
</style>