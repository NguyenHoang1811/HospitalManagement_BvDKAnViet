@model IEnumerable<HospitalManagement_BvDKAnViet.WepApp.Models.AppointmentDTO.AppointmentDto>

@{
    ViewData["Title"] = "Lịch hẹn của tôi";
    var doctorNames = ViewBag.DoctorNames as Dictionary<int, string>
                      ?? new Dictionary<int, string>();
}

<!-- ================= HERO / TIÊU ĐỀ TRANG ================= -->
<div class="patient-hero-banner mb-4">
    <div class="container position-relative z-2">
        <h2 class="fw-bold text-white mb-2">
            <i class="fas fa-calendar-check me-2"></i> Lịch hẹn của tôi
        </h2>
        <p class="text-white-50 mb-0">Theo dõi và quản lý toàn bộ lịch khám của bạn</p>
    </div>
</div>

<div class="container mb-5">

    <!-- ================= HIỂN THỊ THÔNG BÁO ================= -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px;">
            <i class="fas fa-check-circle me-2 fs-5 align-middle"></i>
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert" style="border-radius: 12px;">
            <i class="fas fa-exclamation-circle me-2 fs-5 align-middle"></i>
            <strong>Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- ================= DANH SÁCH LỊCH HẸN ================= -->
    @if (!Model.Any())
    {
        <div class="text-center py-5 mt-4">
            <i class="fas fa-calendar-times fa-4x text-muted mb-3 opacity-50"></i>
            <h5 class="text-muted fw-bold">Bạn chưa có lịch hẹn nào</h5>
            <p class="text-muted small mb-4">Hãy đặt lịch khám trực tuyến để không phải chờ đợi tại bệnh viện.</p>
            <a asp-controller="Appointment" asp-action="BookAppointment" class="btn btn-teal px-4 py-2">
                <i class="fas fa-calendar-plus me-2"></i> Đặt lịch khám ngay
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <!-- Xác định màu badge theo trạng thái -->
                var badgeClass = item.StatusName switch
                {
                    "PENDING" => "badge-pending",
                    "CONFIRMED" => "badge-confirmed",
                    "CANCELLED" => "badge-cancelled",
                    "COMPLETED" => "badge-completed",
                    _ => "badge-pending"
                };

                var badgeIcon = item.StatusName switch
                {
                    "PENDING" => "fas fa-clock",
                    "CONFIRMED" => "fas fa-check-circle",
                    "CANCELLED" => "fas fa-times-circle",
                    "COMPLETED" => "fas fa-check-double",
                    _ => "fas fa-clock"
                };

                var badgeLabel = item.StatusName switch
                {
                    "PENDING" => "Chờ xác nhận",
                    "CONFIRMED" => "Đã xác nhận",
                    "CANCELLED" => "Đã hủy",
                    "COMPLETED" => "Hoàn thành",
                    _ => item.StatusName
                };

                <div class="col-md-6 col-lg-4">
                    <div class="appt-card h-100">

                        <!-- Header card -->
                        <div class="appt-card-header d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center gap-2">
                                <div class="appt-icon">
                                    <i class="fas fa-user-md"></i>
                                </div>
                                <span class="fw-semibold text-navy" style="font-size:15px;">
                                    @(doctorNames.GetValueOrDefault(item.DoctorId, $"Bác sĩ #{item.DoctorId}"))
                                </span>
                            </div>
                            <span class="appt-badge @badgeClass">
                                <i class="@badgeIcon me-1"></i>@badgeLabel
                            </span>
                        </div>

                        <!-- Body card -->
                        <div class="appt-card-body">
                            <div class="appt-info-row">
                                <i class="fas fa-calendar-day text-teal"></i>
                                <span>
                                    @item.AppointmentDate.ToString("dd/MM/yyyy")
                                    <span class="text-muted small ms-1">(@GetDayOfWeek(item.AppointmentDate.DayOfWeek))</span>
                                </span>
                            </div>
                            <div class="appt-info-row">
                                <i class="far fa-clock text-teal"></i>
                                <span class="fw-bold text-navy">@item.AppointmentTime</span>
                            </div>
                            <div class="appt-info-row">
                                <i class="fas fa-hashtag text-teal"></i>
                                <span class="text-muted" style="font-size:13px;">
                                    Mã lịch hẹn: <strong>#HS-@item.AppointmentId.ToString("D3")</strong>
                                </span>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    string GetDayOfWeek(DayOfWeek dow) => dow switch
    {
        DayOfWeek.Monday => "Thứ 2",
        DayOfWeek.Tuesday => "Thứ 3",
        DayOfWeek.Wednesday => "Thứ 4",
        DayOfWeek.Thursday => "Thứ 5",
        DayOfWeek.Friday => "Thứ 6",
        DayOfWeek.Saturday => "Thứ 7",
        DayOfWeek.Sunday => "Chủ nhật",
        _ => ""
    };
}

<style>
    /* ── VARIABLES ── */
    :root {
        --navy: #0f2744;
        --teal: #0d9488;
    }

    .text-navy {
        color: var(--navy) !important;
    }

    .text-teal {
        color: var(--teal) !important;
    }

    /* ── HERO BANNER ── */
    .patient-hero-banner {
        background: linear-gradient(135deg, rgba(15,39,68,0.9) 0%, rgba(13,148,136,0.85) 100%), url('https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center/cover;
        padding: 50px 0;
        box-shadow: 0 10px 30px rgba(13, 148, 136, 0.15);
        border-radius: 0 0 40px 40px; /* Thêm dòng này để bo 2 góc dưới */
        margin-top: -24px; /* Kéo nhẹ banner lên sát viền menu phía trên (nếu cần) */
    }

    /* ── BUTTONS ── */
    .btn-teal {
        background: var(--teal);
        color: white;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-teal:hover {
            background: #0f766e;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(13, 148, 136, 0.3);
        }

    /* ── APPOINTMENT CARD ── */
    .appt-card {
        background: #fff;
        border-radius: 18px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 6px 24px rgba(0,0,0,0.04);
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .appt-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 35px rgba(0,0,0,0.08);
        }

    .appt-card-header {
        padding: 16px 20px;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .appt-icon {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #ccfbf1;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--teal);
        font-size: 16px;
    }

    .appt-card-body {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .appt-info-row {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 14.5px;
        color: #334155;
    }

        .appt-info-row i {
            width: 18px;
            text-align: center;
            font-size: 16px;
        }

    /* ── BADGES ── */
    .appt-badge {
        font-size: 12px;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 20px;
        white-space: nowrap;
        border: 1px solid transparent;
    }

    .badge-pending {
        background: #fef9c3;
        color: #854d0e;
        border-color: #fde047;
    }

    .badge-confirmed {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

    .badge-completed {
        background: #dcfce7;
        color: #15803d;
        border-color: #bbf7d0;
    }

    .badge-cancelled {
        background: #fef2f2;
        color: #b91c1c;
        border-color: #fecaca;
    }
</style>