@model IEnumerable<HospitalManagement_BvDKAnViet.WepApp.Models.MedicalRecordDTO.MedicalRecordDto>
@{
	ViewData["Title"] = "Danh sách Hồ sơ Y tế";
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-3">
		<h2><i class="fas fa-notes-medical"></i> @ViewData["Title"]</h2>
		<a asp-action="Create" class="btn btn-primary">
			<i class="fas fa-plus"></i> Thêm Hồ Sơ
		</a>
	</div>

	@if (TempData["SuccessMessage"] != null)
	{
		<div class="alert alert-success">@TempData["SuccessMessage"]</div>
	}
	@if (TempData["ErrorMessage"] != null)
	{
		<div class="alert alert-danger">@TempData["ErrorMessage"]</div>
	}

	<div class="card p-3">
		<div class="table-responsive">
			<table class="table table-hover">
				<thead class="table-light">
					<tr>
						<th>Mã</th>
						<th>Bệnh Nhân</th>
						<th>Bác Sĩ</th>
						<th>Chẩn đoán</th>
						<th>Ngày Tạo</th>
						<th>Hành động</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var r in Model ?? Enumerable.Empty<HospitalManagement_BvDKAnViet.WepApp.Models.MedicalRecordDTO.MedicalRecordDto>())
					{
						<tr>
							<td>@r.RecordId</td>
							<td>@(string.IsNullOrEmpty(r.PatientName) ? r.PatientId.ToString() : r.PatientName)</td>
							<td>@(string.IsNullOrEmpty(r.DoctorName) ? r.DoctorId.ToString() : r.DoctorName)</td>
							<td>@(string.IsNullOrEmpty(r.Diagnosis) ? "-" : r.Diagnosis.Length > 60 ? r.Diagnosis.Substring(0, 60) + "..." : r.Diagnosis)</td>
							<td>@r.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
							<td>
								<a asp-action="Details" asp-route-id="@r.RecordId" class="btn btn-sm btn-info">Xem</a>
								<a asp-action="Edit" asp-route-id="@r.RecordId" class="btn btn-sm btn-warning">Sửa</a>
								<button type="button"
										class="btn btn-sm btn-danger"
										data-bs-toggle="modal"
										data-bs-target="#deleteModal"
										data-id="@r.RecordId">
									Xóa
								</button>
							</td>
						</tr>
					}
				</tbody>
			</table>
			<div class="modal fade" id="deleteModal" tabindex="-1">
				<div class="modal-dialog modal-dialog-centered">
					<div class="modal-content shadow-lg">

						<div class="modal-header bg-danger text-white">
							<h5 class="modal-title">
								<i class="fas fa-exclamation-triangle"></i> Xác nhận xóa
							</h5>
							<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
						</div>

						<div class="modal-body text-center">
							<p class="fs-5 mb-0">
								Bạn có chắc chắn muốn <strong>xóa hồ sơ này</strong>?
							</p>
						</div>

						<div class="modal-footer justify-content-center">
							<form id="deleteForm" method="post">
								@Html.AntiForgeryToken()
								<button type="submit" class="btn btn-danger px-4">
									<i class="fas fa-trash"></i> Xóa
								</button>
							</form>

							<button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
								Hủy
							</button>
						</div>

					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	var deleteModal = document.getElementById('deleteModal');

	deleteModal.addEventListener('show.bs.modal', function (event) {
		var button = event.relatedTarget;
		var recordId = button.getAttribute('data-id');

		var form = document.getElementById('deleteForm');
		form.action = '/MedicalRecord/Delete/' + recordId;
	});
</script>

<style>
	.card {
		background: #FAFAF8;
		border-radius: 12px;
		box-shadow: 0 8px 16px rgba(0,0,0,0.06), 0 -8px 16px rgba(255,255,255,0.8);
	}

	.btn-primary {
		background: linear-gradient(135deg,#006666,#004d4d);
		border: none;
	}

	.btn-sm {
		margin-right: 6px;
	}

	.modal-content {
		border-radius: 12px;
	}

	.modal-header {
		border-top-left-radius: 12px;
		border-top-right-radius: 12px;
	}

	.modal-body {
		font-size: 16px;
		color: #444;
	}
</style>