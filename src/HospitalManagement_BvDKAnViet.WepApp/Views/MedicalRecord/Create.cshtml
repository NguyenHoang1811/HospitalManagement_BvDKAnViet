@model HospitalManagement_BvDKAnViet.WepApp.Models.MedicalRecordDTO.CreateMedicalRecordDto

@{
    ViewData["Title"] = "Tạo hồ sơ y tế";
    ViewData["Breadcrumb"] = new List<(string Text, string Url)>
    {
        ("Bệnh án", "/MedicalRecord"),
        ("Tạo hồ sơ", null!)  
    };
}

<div class="hms-card">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mx-3 mt-3">
            <i class="fas fa-exclamation-circle"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mx-3 mt-3">
            <i class="fas fa-check-circle"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- HEADER -->
    <div class="hms-card-header">
        <div>
            <div class="panel-title">Tạo hồ sơ y tế</div>
            <div class="panel-sub">Nhập thông tin bệnh án mới</div>
        </div>

        <a asp-action="Index" class="btn-view-all">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    @if (ViewBag.PatientName != null)
    {
        <div class="alert alert-info mx-3 mt-3">
            <i class="fas fa-user-check"></i>
            Đang tạo hồ sơ cho: <b>@ViewBag.PatientName</b>
        </div>
    }

    <!-- FORM -->
    <form method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="row">

            <!-- Patient -->
            <div class="col-md-6 mb-3">
                <label asp-for="PatientId" class="form-label">Bệnh nhân</label>
                <select asp-for="PatientId" id="patientSelect" class="form-select"
                        data-val="false"
                        asp-items="@(ViewBag.Patients as SelectList ?? new SelectList(Enumerable.Empty<object>()))">
                    <option value="">-- Chọn bệnh nhân --</option>
                </select>
                <span asp-validation-for="PatientId" class="text-danger"></span>
            </div>

            <!-- Doctor -->
            <div class="col-md-6 mb-3">
                <label asp-for="DoctorId" class="form-label">Bác sĩ</label> <!-- FIX -->
                <select asp-for="DoctorId" id="doctorSelect" class="form-select"
                        data-val="false"
                        asp-items="@(ViewBag.Doctors as SelectList ?? new SelectList(Enumerable.Empty<object>()))">
                    <option value="">-- Chọn bác sĩ --</option>
                </select>
                <span asp-validation-for="DoctorId" class="text-danger"></span>
            </div>

            <!-- Symptoms -->
            <div class="col-md-12 mb-3">
                <label asp-for="Symptoms" class="form-label">Triệu chứng</label>
                <textarea asp-for="Symptoms" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Symptoms" class="text-danger"></span>
            </div>

            <!-- Diagnosis -->
            <div class="col-md-12 mb-3">
                <label asp-for="Diagnosis" class="form-label">Chẩn đoán</label>
                <textarea asp-for="Diagnosis" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Diagnosis" class="text-danger"></span>
            </div>

            <!-- Treatment -->
            <div class="col-md-12 mb-3">
                <label asp-for="Treatment" class="form-label">Điều trị</label>
                <textarea asp-for="Treatment" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Treatment" class="text-danger"></span>
            </div>

            <!-- Status -->
            <div class="col-md-6 mb-3">
                <label asp-for="MedicalRecordStatus" class="form-label">Trạng thái</label>
                <select asp-for="MedicalRecordStatus" class="form-select">
                    <option value="">-- Chọn trạng thái --</option>
                    <option value="NoiTru">Nội trú</option>
                    <option value="NgoaiTru">Ngoại trú</option>
                    <option value="XuatVien">Xuất viện</option>
                    <option value="CapCuu">Cấp cứu</option>
                </select>
                <span asp-validation-for="MedicalRecordStatus" class="text-danger"></span>
            </div>

            <!-- Result -->
            <div class="col-md-12 mb-3">
                <label asp-for="Result" class="form-label">Kết quả</label>
                <textarea asp-for="Result" class="form-control" rows="3" placeholder="Kết quả khám / xét nghiệm..."></textarea>
                <span asp-validation-for="Result" class="text-danger"></span>
            </div>

            <!-- Note -->
            <div class="col-md-12 mb-3">
                <label asp-for="Note" class="form-label">Ghi chú</label>
                <textarea asp-for="Note" class="form-control" rows="2" placeholder="Ghi chú thêm..."></textarea>
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>

        </div>

        <!-- ACTION -->
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn-primary-hms">
                <i class="fas fa-save"></i> Tạo hồ sơ
            </button>

            <a asp-action="Index" class="btn-view-all">
                Hủy
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Select2 -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {

            $('#patientSelect').select2({
                placeholder: "Tìm bệnh nhân...",
                allowClear: true,
                width: '100%'
            });

            $('#doctorSelect').select2({
                placeholder: "Tìm bác sĩ...",
                allowClear: true,
                width: '100%'
            });

        });
    </script>

    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            var valid = true;

            var patientId = document.querySelector('[name="PatientId"]').value;
            var patientErr = document.querySelector('[data-valmsg-for="PatientId"]');
            if (!patientId || patientId === '') {
                if (patientErr) patientErr.textContent = 'Vui lòng chọn bệnh nhân';
                valid = false;
            } else {
                if (patientErr) patientErr.textContent = '';
            }

            var doctorId = document.querySelector('[name="DoctorId"]').value;
            var doctorErr = document.querySelector('[data-valmsg-for="DoctorId"]');
            if (!doctorId || doctorId === '') {
                if (doctorErr) doctorErr.textContent = 'Vui lòng chọn bác sĩ';
                valid = false;
            } else {
                if (doctorErr) doctorErr.textContent = '';
            }

            if (!valid) e.preventDefault();
        });
    </script>
}

<style>
    .select2-container .select2-selection--single {
        height: 38px !important;
        border-radius: 6px;
        display: flex !important;
        align-items: center !important;
    }

    .select2-selection__rendered {
        line-height: normal !important;
        padding-left: 0 !important;
    }

    .select2-selection__arrow {
        height: 100% !important;
        top: 0 !important;
    }
</style>