@model HospitalManagement_BvDKAnViet.WepApp.Models.MedicalRecordDTO.UpdateMedicalRecordDto
@{
    ViewData["Title"] = "Tạo hồ sơ y tế";

    ViewData["Breadcrumb"] = new List<(string Text, string Url)>
    {
        ("Bệnh án", "/MedicalRecord"),
        ("Sửa hồ sơ", null!)
    };
}

<div class="hms-card">

    <!-- HEADER -->
    <div class="hms-card-header">
        <div>
            <div class="panel-title">
                <i class="fas fa-edit me-2"></i> @ViewData["Title"]
            </div>
            <div class="panel-sub">Cập nhật thông tin hồ sơ bệnh án</div>
        </div>

        <a asp-action="Index" class="btn-view-all">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <!-- FORM -->
    <form asp-action="Edit" asp-route-id="@ViewBag.RecordId"
          method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="row g-3">

            <!-- Patient -->
            <div class="col-md-6">
                <label asp-for="PatientId" class="form-label">Bệnh nhân</label>
                <select asp-for="PatientId" class="form-control" asp-items="ViewBag.Patients">
                    <option value="">-- Chọn bệnh nhân --</option>
                </select>
                <span asp-validation-for="PatientId" class="text-danger"></span>
            </div>

            <!-- Doctor -->
            <div class="col-md-6">
                <label asp-for="DoctorId" class="form-label">Bác sĩ</label>
                <select asp-for="DoctorId" class="form-control" asp-items="ViewBag.Doctors">
                    <option value="">-- Chọn bác sĩ --</option>
                </select>
                <span asp-validation-for="DoctorId" class="text-danger"></span>
            </div>

            <!-- Symptoms -->
            <div class="col-12">
                <label asp-for="Symptoms" class="form-label">Triệu chứng</label>
                <textarea asp-for="Symptoms" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Symptoms" class="text-danger"></span>
            </div>

            <!-- Diagnosis -->
            <div class="col-12">
                <label asp-for="Diagnosis" class="form-label">Chẩn đoán</label>
                <textarea asp-for="Diagnosis" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Diagnosis" class="text-danger"></span>
            </div>

            <!-- Treatment -->
            <div class="col-12">
                <label asp-for="Treatment" class="form-label">Điều trị</label>
                <textarea asp-for="Treatment" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Treatment" class="text-danger"></span>
            </div>

            <!-- MedicalRecordStatus -->
            <div class="col-md-6">
                <label asp-for="MedicalRecordStatus" class="form-label">Trạng thái</label>

                <div class="d-flex flex-column justify-content-between h-100">
                    <select asp-for="MedicalRecordStatus" class="form-select">
                        <option value="">-- Chọn trạng thái --</option>
                        <option value="NoiTru">Nội trú</option>
                        <option value="NgoaiTru">Ngoại trú</option>
                        <option value="XuatVien">Xuất viện</option>
                        <option value="CapCuu">Cấp cứu</option>
                    </select>

                    <span asp-validation-for="MedicalRecordStatus" class="text-danger"></span>
                </div>
            </div>

            <!-- Attachment -->
            <div class="col-md-6">
                <label asp-for="Attachment" class="form-label">Tệp đính kèm</label>

                <div class="d-flex flex-column gap-2">

                    <!-- dòng 1: nút xem file -->
                    @if (!string.IsNullOrEmpty(Model.Attachment))
                    {
                        <a href="~/@Model.Attachment" target="_blank"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-file"></i> Xem file
                        </a>
                    }

                    <!-- dòng 2: input file -->
                    <input type="file" name="file" class="form-control" />

                    <input type="hidden" asp-for="Attachment" />
                </div>

                <span asp-validation-for="Attachment" class="text-danger"></span>
            </div>

            <!-- Result -->
            <div class="col-12">
                <label asp-for="Result" class="form-label">Kết quả</label>
                <textarea asp-for="Result" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Result" class="text-danger"></span>
            </div>

            <!-- Note -->
            <div class="col-12">
                <label asp-for="Note" class="form-label">Ghi chú</label>
                <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Note" class="text-danger"></span>
            </div>

        </div>

        <!-- ACTIONS -->
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn-teal-hms">
                <i class="fas fa-save"></i> Lưu thay đổi
            </button>

            <a asp-action="Index" class="btn-view-all">
                Hủy
            </a>
        </div>
    </form>

</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}