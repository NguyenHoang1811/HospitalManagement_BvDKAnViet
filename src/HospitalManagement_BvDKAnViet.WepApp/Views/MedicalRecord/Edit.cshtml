@model HospitalManagement_BvDKAnViet.WepApp.Models.AccountDTO.LoginRequestDto
@{
    ViewData["Title"] = "Đăng Nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập - Hospital System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #f1f5f9;
        }

        .container-login {
            display: flex;
            min-height: 100vh;
        }

        /* LEFT BRAND PANEL */
        .brand-panel {
            width: 40%;
            background: #0f2744;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px;
        }

            .brand-panel h1 {
                font-size: 32px;
                font-weight: 700;
            }

            .brand-panel p {
                color: #94a3b8;
            }

        /* RIGHT FORM */
        .form-panel {
            width: 60%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: white;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        .login-title {
            font-size: 22px;
            font-weight: 600;
            color: #1e293b;
        }

        .login-sub {
            font-size: 13px;
            color: #64748b;
            margin-bottom: 25px;
        }

        .form-control {
            height: 44px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
        }

            .form-control:focus {
                border-color: #2dd4bf;
                box-shadow: 0 0 0 2px rgba(45,212,191,0.2);
            }

        .input-group-text {
            background: white;
            border-radius: 10px 0 0 10px;
        }

        .btn-login {
            width: 100%;
            height: 44px;
            border-radius: 10px;
            background: #2dd4bf;
            border: none;
            font-weight: 600;
        }

            .btn-login:hover {
                background: #26c6a8;
            }

        .alert {
            font-size: 13px;
        }

        .footer-text {
            font-size: 12px;
            color: #94a3b8;
            text-align: center;
            margin-top: 20px;
        }

    </style>
</head>

<body>
    <div class="container-login">

        <!-- LEFT -->
        <div class="brand-panel">
            <h1>Bệnh viện Đa khoa An Việt</h1>
            <p>Hệ thống quản lý & theo dõi bệnh viện</p>
        </div>

        <!-- RIGHT -->
        <div class="form-panel">
            <div class="login-card">

                <div class="login-title">Đăng nhập hệ thống</div>
                <div class="login-sub">Nhập thông tin để truy cập dashboard</div>

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger">
                        @foreach (var v in ViewData.ModelState.Values)
                        {
                            foreach (var e in v.Errors)
                            {
                                <div>@e.ErrorMessage</div>
                            }
                        }
                    </div>
                }

                <form method="post" asp-action="Login" asp-controller="Auth">

                    <!-- USER -->
                    <div class="mb-3">
                        <label class="form-label">Tên đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="fas fa-user"></i>
                            </span>
                            <input asp-for="Username" class="form-control" placeholder="Username" />
                        </div>
                    </div>

                    <!-- PASS -->
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                        </div>
                    </div>

                    <button class="btn btn-login">
                        <i class="fas fa-sign-in-alt me-2"></i> Đăng nhập
                    </button>

                </form>

                <div class="footer-text">
                    © 2026 Hospital System
                </div>

            </div>
        </div>

    </div>
</body>
</html>