@model HospitalManagement_BvDKAnViet.WepApp.Models.PatientDTO.CreatePatientDto
@{
    ViewData["Title"] = "Thêm Bệnh Nhân Mới";
}

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">@ViewData["Title"]</h2>
            <div class="text-muted small">Nhập thông tin bệnh nhân vào hệ thống</div>
        </div>
    </div>

    <!-- ERROR -->
    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger shadow-sm">
            <i class="fas fa-exclamation-circle"></i>
            @foreach (var v in ViewData.ModelState.Values)
            {
                foreach (var e in v.Errors)
                {
                    <div>@e.ErrorMessage</div>
                }
            }
        </div>
    }

    <!-- FORM -->
    <div class="card-custom">
        <form asp-action="Create" method="post" novalidate>

            <!-- NAME -->
            <div class="mb-3">
                <label class="form-label">Họ tên *</label>
                <input asp-for="Name"
                       class="form-control @(ViewData.ModelState["Name"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       placeholder="Nhập họ và tên đầy đủ" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <!-- DOB + GENDER -->
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Ngày sinh *</label>
                    <input type="date"
                           asp-for="DateOfBirth"
                           class="form-control @(ViewData.ModelState["DateOfBirth"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                    <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Giới tính *</label>

                    <div class="d-flex gap-3 mt-2">
                        <label class="radio-card">
                            <input type="radio" name="Gender" value="M" />
                            <span><i class="fas fa-mars"></i> Nam</span>
                        </label>

                        <label class="radio-card">
                            <input type="radio" name="Gender" value="F" />
                            <span><i class="fas fa-venus"></i> Nữ</span>
                        </label>
                    </div>

                    <span asp-validation-for="Gender" class="text-danger small"></span>
                </div>
            </div>

            <!-- PHONE + ADDRESS -->
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Số điện thoại *</label>
                    <input asp-for="Phone"
                           class="form-control @(ViewData.ModelState["Phone"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Ví dụ: 0987654321" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Địa chỉ *</label>
                    <input asp-for="Address"
                           class="form-control @(ViewData.ModelState["Address"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           placeholder="Số nhà, đường, quận/huyện..." />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
            </div>

            <!-- MEDICAL -->
            <div class="mb-3">
                <label class="form-label">Lịch sử y tế</label>
                <textarea asp-for="MedicalHistory"
                          class="form-control"
                          placeholder="Ghi chú bệnh án, dị ứng, tiền sử..."></textarea>
            </div>

            <!-- ACTION -->
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-accent">
                    <i class="fas fa-check"></i> Tạo bệnh nhân
                </button>

                <a asp-action="Index" class="btn btn-light">
                    Hủy
                </a>
            </div>

        </form>
    </div>
</div>

<style>
    .page-wrapper {
        padding: 10px;
    }

    /* CARD */
    .card-custom {
        background: #fff;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.05);
    }

    /* INPUT */
    .form-control {
        height: 44px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #2dd4bf;
            box-shadow: 0 0 0 2px rgba(45,212,191,0.2);
        }

    /* TEXTAREA */
    textarea.form-control {
        min-height: 100px;
    }

    /* RADIO CARD */
    .radio-card {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        cursor: pointer;
    }

        .radio-card input {
            accent-color: #2dd4bf;
        }

    /* BUTTON */
    .btn-accent {
        background: #2dd4bf;
        color: white;
        border-radius: 8px;
    }

        .btn-accent:hover {
            background: #26c6a8;
        }
</style>